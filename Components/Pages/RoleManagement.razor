@page "/RoleManagement"
@using CampusServicePortal.Repositories
@using CampusServicePortal.Data
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject ICampusRepository Repo
@inject UserSession Session
@inject NavigationManager Nav

@code {
    protected override void OnInitialized()
    {
        if (!Session.IsLoggedIn)
        {
            Nav.NavigateTo("/login");
        }
    }
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary">User Role Management</h2>
        <span class="badge bg-dark text-uppercase">Admin Access</span>
    </div>

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="alert alert-success shadow-sm">@statusMessage</div>
    }

    @if (isLoading)
    {
        <div class="text-center mt-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Synchronizing permissions...</p>
        </div>
    }
    else
    {
        <div class="card shadow border-0">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th class="ps-4">Full Name</th>
                                <th>Email</th>
                                <th>Current Role</th>
                                <th class="pe-4">Change Role</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in users)
                            {
                                <tr>
                                    <td>@user.FullName</td>
                                    <td>@user.Email</td>
                                    <td>
                                        <span class="badge bg-info text-dark">
                                            @(user.Role?.RoleName ?? "No Role")
                                        </span>
                                    </td>
                                    <td>
                                        @* Change e.Value to use RoleId *@
                                        <select class="form-select" @onchange="@(async (e) => await ChangeRole(user.UserId, e))">
                                            <option value="">-- Assign Role --</option>
                                            @foreach (var role in roles)
                                            {
                                                @* Matches the 'RoleId' property we just added *@
                                                <option value="@role.RoleId">@role.RoleName</option>
                                            }
                                        </select>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<User> users = new();
    private List<Role> roles = new();
    private bool isLoading = true;
    private string statusMessage = "";

    protected override async Task OnInitializedAsync()
    {
        await RefreshData();
    }

    private async Task RefreshData()
    {
        try
        {
            isLoading = true;
            users = await Repo.GetUsersAsync();
            roles = await Repo.GetRolesAsync();
        }
        catch (Exception ex)
        {
            statusMessage = "Error: " + ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ChangeRole(int userId, ChangeEventArgs e)
    {
        if (string.IsNullOrEmpty(e.Value?.ToString())) return;

        try
        {
            int newRoleId = int.Parse(e.Value.ToString()!);
            await Repo.UpdateUserRoleAsync(userId, newRoleId);
            
            statusMessage = "User role updated successfully!";
            await RefreshData(); // Refresh UI
        }
        catch (Exception ex)
        {
            statusMessage = "Update Failed: " + ex.Message;
        }
    }
}