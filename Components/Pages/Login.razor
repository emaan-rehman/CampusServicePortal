@page "/login"
@using CampusServicePortal.Data
@using CampusServicePortal.Repositories
@inject ICampusRepository Repo
@inject UserSession Session
@inject NavigationManager Nav

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-4">
            <div class="card shadow border-0 p-4">
                <h3 class="text-center fw-bold text-primary mb-4">Portal Login</h3>
                
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger p-2 small">@errorMessage</div>
                }

                <div class="mb-3">
                    <label class="form-label">Email Address</label>
                    <input type="email" class="form-control" @bind="loginEmail" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Password</label>
                    <input type="password" class="form-control" @bind="loginPassword" />
                </div>
                
                <button class="btn btn-primary w-100 py-2 fw-bold" @onclick="HandleLogin">
                    Sign In
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    private string loginEmail = "";
    private string loginPassword = "";
    private string errorMessage = "";

    private async Task HandleLogin()
    {
        var user = await Repo.AuthenticateUserAsync(loginEmail, loginPassword);
        if (user != null)
        {
            UserSession.CurrentUser = user;
            // FORCE LOAD is the key. It restarts the app state so the Sidebar refreshes.
            Nav.NavigateTo("/", forceLoad: true);
        }
        else
        {
            errorMessage = "Invalid credentials.";
        }
    }
}