@page "/fees"
@using CampusServicePortal.Data
@using CampusServicePortal.Repositories
@inject ICampusRepository Repo

<div class="container mt-4">
    <h2 class="fw-bold mb-4"><i class="bi bi-wallet2 text-success"></i> Fee Details</h2>

    @if (feeList == null)
    {
        <p>Loading fees...</p>
    }
    else if (!feeList.Any())
    {
        <div class="alert alert-info">No fee records found.</div>
    }
    else
    {
        <div class="row">
            @foreach (var fee in feeList)
            {
                <div class="col-md-4 mb-3">
                    <div class="card shadow-sm @(fee.IsPaid == true ? "border-success" : "border-danger")">
                        <div class="card-body">
                            <h5 class="card-title text-muted small uppercase">Amount Due</h5>
                            <h3 class="fw-bold">$@fee.Amount</h3>
                            <hr />
                            <p class="mb-1"><strong>Due Date:</strong> @fee.DueDate?.ToShortDateString()</p>
                            <p class="mb-0">
                                <strong>Status:</strong>
                                <span class="badge @(fee.IsPaid == true ? "bg-success" : "bg-danger")">
                                    @(fee.IsPaid == true ? "Paid" : "Pending")
                                </span>
                            </p>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<Fee>? feeList;

    protected override async Task OnInitializedAsync()
    {
        // Use the current logged-in user's ID
        if (UserSession.CurrentUser != null)
        {
            feeList = await Repo.GetStudentFeesAsync(UserSession.CurrentUser.UserId);
        }
    }
}