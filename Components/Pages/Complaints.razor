@page "/complaints"
@using CampusServicePortal.Repositories
@using CampusServicePortal.Data
@rendermode InteractiveServer
@inject ICampusRepository Repo
@using System.ComponentModel.DataAnnotations

<div class="container mt-4">
    <h3 class="mb-4">Campus Complaint Portal</h3>

    <EditForm Model="@newComplaint" OnValidSubmit="HandleSubmit" class="card p-4 shadow-sm mb-5">
        <DataAnnotationsValidator />
        <div class="mb-3">
            <label>Issue Title</label>
            <InputText @bind-Value="newComplaint.Title" class="form-control" />
            <ValidationMessage For="@(() => newComplaint.Title)" />
        </div>
        <div class="mb-3">
            <label>Detailed Description</label>
            <InputTextArea @bind-Value="newComplaint.Description" class="form-control" />
        </div>
        <button type="submit" class="btn btn-primary">Submit Complaint</button>
    </EditForm>

    <table class="table">
        <tbody>
            @foreach (var complaint in complaintList)
            {
                <tr>
                    <td><strong>@complaint.Title</strong></td>
                    <td>
                        @if (complaint.Status == "Pending")
                        {
                            <span class="badge bg-warning text-dark"><i class="bi bi-clock-history"></i> Pending</span>
                        }
                        else
                        {
                            <span class="badge bg-success"><i class="bi bi-check-circle"></i> Resolved</span>
                        }
                    </td>
                    <td>@complaint.CreatedAt.ToShortDateString()</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    private Complaint newComplaint = new();
    private List<Complaint> complaintList = new();

    protected override async Task OnInitializedAsync()
    {
        complaintList = await Repo.GetComplaintsAsync();
    }

    private async Task HandleSubmit()
    {
        // Ensure the ID is set to something valid in your DB for now
        // In a real app, this would be the logged-in User's ID
        newComplaint.UserId = 1;
        newComplaint.CreatedAt = DateTime.Now;
        newComplaint.Status = "Pending";

        await Repo.CreateComplaintAsync(newComplaint);
    
        // Refresh and Reset
        complaintList = await Repo.GetComplaintsAsync();
        newComplaint = new();
    }
}