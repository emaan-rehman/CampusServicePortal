@page "/cafe"
@using CampusServicePortal.Data
@using CampusServicePortal.Repositories
@inject ICampusRepository Repo

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark d-flex align-items-center gap-2 m-0">
            <i class="bi bi-cup-hot text-success"></i> Campus Café Menu
        </h2>
        
        <div class="d-flex align-items-center gap-3">
            @if (IsAdmin)
            {
                <button class="btn btn-success shadow-sm fw-bold d-flex align-items-center gap-2"
                        style="border-radius: 8px; padding: 10px 16px; font-size: 0.9rem;"
                        @onclick="() => showForm = !showForm">
                    <i class="bi @(showForm ? "bi-x-circle" : "bi-plus-circle")"></i>
                    @(showForm ? "Close Form" : "Add Item")
                </button>
            }

            @if (!string.IsNullOrEmpty(alertMessage))
            {
                <div class="alert alert-@alertClass alert-dismissible fade show m-0 py-2 px-3 align-middle shadow-sm" role="alert" style="border-radius: 8px; font-size: 0.9rem;">
                    <i class="bi @(alertClass == "success" ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill") me-2"></i>
                    @alertMessage
                    <button type="button" class="btn-close py-2.5" @onclick="ClearAlert" aria-label="Close"></button>
                </div>
            }
        </div>
    </div>

    @if (showForm && IsAdmin)
    {
        <div class="card card-body mb-4 shadow-sm border-0 p-4" style="border-radius: 16px; border-left: 5px solid #198754 !important; background-color: #FFFFFF;">
            <h5 class="fw-bold mb-3 text-dark d-flex align-items-center gap-2">
                <i class="bi bi-plus-square-fill text-success"></i> Register New Menu Product
            </h5>
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label small fw-bold text-muted">Item Name</label>
                    <input type="text" class="form-control bg-light" placeholder="e.g., Club Sandwich" @bind="newItem.ItemName" />
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-bold text-muted">Price (PKR / USD)</label>
                    <input type="number" class="form-control bg-light" placeholder="Price" @bind="newItem.Price" />
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-bold text-muted">Category</label>
                    <input type="text" class="form-control bg-light" placeholder="e.g., Beverages, Snacks" @bind="newItem.Category" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-primary w-100 fw-bold py-2" style="border-radius: 8px; background-color: #1E293B; border: none;" @onclick="SaveItem">
                        <i class="bi bi-cloud-arrow-up-fill me-1"></i> Save Item
                    </button>
                </div>
            </div>
        </div>
    }

    @if (menuItems == null)
    {
        <div class="d-flex align-items-center text-muted gap-2">
            <div class="spinner-border spinner-border-sm text-success" role="status"></div>
            <span>Loading delicious menu configurations...</span>
        </div>
    }
    else if (!menuItems.Any())
    {
        <div class="alert alert-info border-0 shadow-sm" style="border-radius: 10px;">
            <i class="bi bi-info-circle-fill me-2"></i> No menu items are currently registered in the database.
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
            @foreach (var item in menuItems)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0 position-relative transition-style"
                         style="border-radius: 16px; background-color: #FFFFFF; border: 1px solid #E2E8F0 !important;">
                        <div class="card-body p-3 d-flex flex-column justify-content-between" style="min-height: 120px;">
                            <div>
                                <span class="badge bg-light text-success border border-success mb-2" style="font-size: 0.7rem; font-weight: 600;">
                                    @item.Category
                                </span>
                                <h5 class="mb-0 fw-bold text-dark" style="letter-spacing: -0.3px;">@item.ItemName</h5>
                            </div>
                            <div class="text-md-end mt-3">
                                <span class="text-success fw-bold h5 mb-0">Rs. @item.Price</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .transition-style:hover {
        transform: translateY(-4px);
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05), 0 4px 6px -2px rgba(0, 0, 0, 0.05) !important;
        transition: all 0.25s ease-in-out;
    }
</style>

@code {
    private List<MenuItem>? menuItems;
    private bool showForm = false;
    private MenuItem newItem = new MenuItem();
 
    private string alertMessage = string.Empty;
    private string alertClass = "success";

    private bool IsAdmin => UserSession.CurrentUser?.Role?.RoleName == "Admin" || UserSession.CurrentUser?.RoleId == 1;

    protected override async Task OnInitializedAsync() => await LoadMenu();

    private async Task LoadMenu() => menuItems = await Repo.GetCafeMenuAsync();

    private async Task SaveItem()
    {
        if (!IsAdmin)
        {
            TriggerNotification("Unauthorized operation validation failed.", "danger");
            return;
        }

        if (string.IsNullOrWhiteSpace(newItem.ItemName))
        {
            TriggerNotification("Please provide a valid product item name.", "danger");
            return;
        }

        try
        {
            await Repo.AddMenuItemAsync(newItem);
            TriggerNotification($"Product '{newItem.ItemName}' successfully updated into cafeteria tracking roster!", "success");
      
            newItem = new MenuItem();
            showForm = false;
            
            await LoadMenu();
        }
        catch (Exception ex)
        {
            TriggerNotification($"Database synchronization crash error: {ex.Message}", "danger");
        }
    }

    private void TriggerNotification(string msg, string type)
    {
        alertMessage = msg;
        alertClass = type;
    }

    private void ClearAlert()
    {
        alertMessage = string.Empty;
    }
}