@page "/cafe"
@using CampusServicePortal.Data
@using CampusServicePortal.Repositories
@inject ICampusRepository Repo

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold"><i class="bi bi-cup-hot text-success"></i> Campus Café Menu</h2>
        @if (IsAdmin)
        {
            <button class="btn btn-success" @onclick="() => showForm = !showForm">
                @(showForm ? "Close" : "Add Item")
            </button>
        }
    </div>

    @if (showForm && IsAdmin)
    {
        <div class="card card-body mb-4 border-success shadow-sm">
            <div class="row g-3">
                <div class="col-md-4"><input type="text" class="form-control" placeholder="Item Name" @bind="newItem.ItemName" /></div>
                <div class="col-md-3"><input type="number" class="form-control" placeholder="Price" @bind="newItem.Price" /></div>
                <div class="col-md-3"><input type="text" class="form-control" placeholder="Category" @bind="newItem.Category" /></div>
                <div class="col-md-2"><button class="btn btn-primary w-100" @onclick="SaveItem">Save</button></div>
            </div>
        </div>
    }

    @if (menuItems == null)
    {
        <p>Loading delicious menu...</p>
    }
    else
    {
        <div class="row">
            @foreach (var item in menuItems)
            {
                <div class="col-md-4 mb-3">
                    <div class="card h-100 shadow-sm border-0 bg-light">
                        <div class="card-body d-flex justify-content-between align-items-center">
                            <div>
                                <h5 class="mb-0 fw-bold">@item.ItemName</h5>
                                <small class="text-muted">@item.Category</small>
                            </div>
                            <div class="text-success fw-bold h5 mb-0">$@item.Price</div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<MenuItem>? menuItems;
    private bool showForm = false;
    private MenuItem newItem = new MenuItem();
    private bool IsAdmin => UserSession.CurrentUser?.Role?.RoleName == "Admin" || UserSession.CurrentUser?.RoleId == 1;

    protected override async Task OnInitializedAsync() => await LoadMenu();

    private async Task LoadMenu() => menuItems = await Repo.GetCafeMenuAsync();

    private async Task SaveItem()
    {
        if (!string.IsNullOrEmpty(newItem.ItemName))
        {
            await Repo.AddMenuItemAsync(newItem);
            newItem = new MenuItem();
            showForm = false;
            await LoadMenu();
        }
    }
}