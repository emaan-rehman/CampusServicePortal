@page "/events"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using CampusServicePortal.Repositories
@using CampusServicePortal.Data
@inject ICampusRepository Repo

<div class="container mt-4">
    @* --- TOP HEADER AND ADMIN UTILITY CONTROL --- *@
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="fw-bold text-dark m-0">
            <i class="bi bi-calendar-event text-primary me-2"></i>Upcoming Campus Events
        </h3>
        
        <div class="d-flex align-items-center gap-2">
            @if (events != null)
            {
                <span class="badge bg-secondary p-2">@events.Count Events Found</span>
            }

            @* --- CRITICAL ROLE CHECK: "Add Event" Button is strictly ONLY for Admin --- *@
            @if (IsAdmin)
            {
                <button class="btn btn-primary shadow-sm fw-bold d-flex align-items-center gap-2"
                        style="background-color: #1E293B; border: none; border-radius: 8px; padding: 8px 14px; font-size: 0.85rem;"
                        @onclick="() => showForm = !showForm">
                    <i class="bi @(showForm ? "bi-x-circle" : "bi-plus-circle")"></i>
                    @(showForm ? "Close Form" : "Add Event")
                </button>
            }
        </div>
    </div>
    <hr />

    @* --- STATUS NOTIFICATION FEEDBACK --- *@
    @if (!string.IsNullOrEmpty(regMessage))
    {
        <div class="alert alert-@alertClass alert-dismissible fade show shadow-sm" style="border-radius: 8px;">
            <i class="bi @(alertClass == "success" ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill") me-2"></i>
            @regMessage
            <button type="button" class="btn-close" @onclick='() => regMessage = ""'></button>
        </div>
    }

    @* --- CRITICAL ROLE CHECK: Form Module is strictly ONLY rendered for Admin --- *@
    @if (showForm && IsAdmin)
    {
        <div class="card card-body mb-4 shadow-sm border-0 p-4" style="border-radius: 16px; border-left: 5px solid #0D6EFD !important; background-color: #FFFFFF;">
            <h5 class="fw-bold mb-3 text-dark d-flex align-items-center gap-2">
                <i class="bi bi-plus-square-fill text-primary"></i> Host New Campus Event
            </h5>
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label small fw-bold text-muted">Event Title</label>
                    <input type="text" class="form-control bg-light" placeholder="e.g., Annual Tech Fest 2026" @bind="newEvent.Title" />
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-bold text-muted">Venue / Location</label>
                    <input type="text" class="form-control bg-light" placeholder="e.g., Main Auditorium" @bind="newEvent.Location" />
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-bold text-muted">Event Date</label>
                    <input type="date" class="form-control bg-light" @bind="newEvent.Date" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-success w-100 fw-bold py-2" style="border-radius: 8px;" @onclick="SaveEvent">
                        <i class="bi bi-cloud-arrow-up-fill me-1"></i> Save Event
                    </button>
                </div>
            </div>
        </div>
    }

    @* --- DATA RENDERING MATRIX GRID --- *@
    @if (events == null)
    {
        <div class="text-center mt-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2">Connecting to campus database...</p>
        </div>
    }
    else if (!events.Any())
    {
        <div class="alert alert-info shadow-sm text-center py-5" style="border-radius: 12px;">
            <i class="bi bi-calendar-x fs-1 d-block mb-3"></i>
            No upcoming events found at this time. Check back later!
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var ev in events)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0 border-top border-primary border-4 transition-style" style="border-radius: 12px;">
                        <div class="card-body p-3 d-flex flex-column justify-content-between">
                            <div>
                                <h5 class="card-title fw-bold text-dark mb-2">@ev.Title</h5>
                                <p class="card-text mb-1">
                                    <small class="text-muted">
                                        <i class="bi bi-geo-alt-fill text-danger me-1"></i> @(ev.Location ?? "Main Campus")
                                    </small>
                                </p>
                                <p class="card-text mb-3">
                                    <small class="text-muted">
                                        <i class="bi bi-calendar-check-fill text-primary me-1"></i> @ev.Date.ToString("MMMM dd, yyyy")
                                    </small>
                                </p>
                            </div>
                            
                            <button class="btn btn-outline-primary btn-sm w-100 mt-2 fw-semibold" style="border-radius: 6px;"
                                    @onclick="() => Register(ev.Title)">
                                <i class="bi bi-pencil-square me-1"></i> Register Now
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .transition-style:hover {
        transform: translateY(-4px);
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05) !important;
        transition: all 0.2s ease-in-out;
    }
</style>

@code {
    private List<CampusEvent>? events;
    private CampusEvent newEvent = new CampusEvent { Date = DateTime.Today };
    private bool showForm = false;
    
    // Feedback parameters
    private string regMessage = "";
    private string alertClass = "success";

    private bool IsAdmin => UserSession.CurrentUser?.Role?.RoleName == "Admin" || UserSession.CurrentUser?.RoleId == 1;

    protected override async Task OnInitializedAsync() => await LoadEvents();

    private async Task LoadEvents()
    {
        try
        {
            events = await Repo.GetEventsAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Database Error: {ex.Message}");
            events = new List<CampusEvent>();
        }
    }

    private async Task SaveEvent()
    {
        // Double safety role-lock block implementation
        if (!IsAdmin)
        {
            TriggerNotification("Unauthorized operation validation failed.", "danger");
            return;
        }

        if (string.IsNullOrWhiteSpace(newEvent.Title))
        {
            TriggerNotification("Please provide a valid Event Title description.", "danger");
            return;
        }

        try
        {
            await Repo.AddEventAsync(newEvent);
            TriggerNotification($"Event '{newEvent.Title}' successfully updated into database infrastructure!", "success");
            
            // State variable resets
            newEvent = new CampusEvent { Date = DateTime.Today };
            showForm = false;
            
            await LoadEvents();
        }
        catch (Exception ex)
        {
            TriggerNotification($"Database save error: {ex.Message}", "danger");
        }
    }

    private void Register(string eventTitle)
    {
        TriggerNotification($"Success! You have registered for: {eventTitle}", "success");
    }

    private void TriggerNotification(string msg, string type)
    {
        regMessage = msg;
        alertClass = type;
    }
}