@page "/events"
@rendermode InteractiveServer
@using CampusServicePortal.Repositories
@using CampusServicePortal.Data
@inject ICampusRepository Repo
@using System.ComponentModel.DataAnnotations

<div class="container mt-4">
    <h3>Upcoming Campus Events</h3>
    <div class="card mb-3">
        <div class="card-body">
            <h5 class="card-title">Annual Tech Fest 2026</h5>
            <p class="card-text">Date: June 15, 2026 | Location: Main Auditorium</p>
            <button class="btn btn-primary">Register Now</button>
        </div>
    </div>
</div>