@page "/exams"
@using CampusServicePortal.Data
@using CampusServicePortal.Repositories
@inject ICampusRepository Repo

<div class="container mt-4">
    @* --- TOP HEADER AND ADMIN CONSOLE PANEL --- *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark d-flex align-items-center gap-2 m-0">
            <i class="bi bi-file-earmark-text text-danger fs-2"></i>
            @(IsAdmin ? "Exam Management Portal" : "Exam Schedule")
        </h2>
        
        <div class="d-flex align-items-center gap-3">
            @if (IsAdmin)
            {
                <button class="btn btn-danger shadow-sm fw-bold d-flex align-items-center gap-2"
                        style="border-radius: 8px; padding: 10px 16px; font-size: 0.9rem;"
                        @onclick="ToggleFormPanel">
                    <i class="bi @(showForm ? "bi-x-circle" : "bi-plus-circle")"></i>
                    @(showForm ? "Close Form" : isEditing ? "Cancel Edit" : "Add New Schedule")
                </button>
            }

            @if (!string.IsNullOrEmpty(alertMessage))
            {
                <div class="alert alert-@alertClass alert-dismissible fade show m-0 py-2 px-3 align-middle shadow-sm" role="alert" style="border-radius: 8px; font-size: 0.9rem;">
                    <i class="bi @(alertClass == "success" ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill") me-2"></i>
                    @alertMessage
                    <button type="button" class="btn-close py-2.5" @onclick="ClearAlert" aria-label="Close"></button>
                </div>
            }
        </div>
    </div>

    @* --- DYNAMIC FORM PANEL: HANDLING BOTH INSERT AND UPDATE --- *@
    @if (showForm && IsAdmin)
    {
        @* Dynamic styling properties processed safely outside the HTML layout string constraints *@
        var borderIndicatorColor = isEditing ? "#0D6EFD" : "#DC3545";
        var formHeadingText = isEditing ? "Modify Existing Exam Record" : "Add New Exam Entry";
        var headingIconClass = isEditing ? "bi-pencil-square text-primary" : "bi-plus-square-fill text-danger";

        <div class="card card-body mb-4 shadow-sm border-0 p-4"
             style="border-radius: 16px; border-left: 5px solid @borderIndicatorColor !important; background-color: #FFFFFF;">
            
            <h5 class="fw-bold mb-3 text-dark d-flex align-items-center gap-2">
                <i class="bi @headingIconClass"></i> @formHeadingText
            </h5>
            
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label small fw-bold text-muted">Subject Name</label>
                    <input type="text" class="form-control bg-light" placeholder="e.g., Software Engineering" @bind="newExam.SubjectName" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-bold text-muted">Course Code</label>
                    <input type="text" class="form-control bg-light" placeholder="e.g., CS-101" @bind="newExam.SubjectCode" />
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-bold text-muted">Date & Time</label>
                    <input type="datetime-local" class="form-control bg-light" @bind="newExam.ExamDate" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-bold text-muted">Room / Venue</label>
                    <input type="text" class="form-control bg-light" placeholder="e.g., Room 204" @bind="newExam.Room" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn @(isEditing ? "btn-primary" : "btn-success") w-100 fw-bold py-2" style="border-radius: 8px;" @onclick="SaveExam">
                        <i class="bi bi-cloud-arrow-up-fill me-1"></i> @(isEditing ? "Update" : "Save")
                    </button>
                </div>
            </div>
        </div>
    }

    @* --- DATA TABLE MATRIX --- *@
    @if (exams == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-danger" role="status"></div>
            <p class="mt-2 text-muted">Fetching examination data configuration rosters...</p>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0 transition-style" style="border-radius: 12px; overflow: hidden;">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="@(IsAdmin ? "table-dark" : "table-danger text-white")">
                            <tr>
                                <th class="ps-4 py-3">Subject Name</th>
                                <th class="py-3">Subject Code</th>
                                <th class="py-3">Date & Time</th>
                                <th class="py-3">Venue / Hall</th>
                                @if (IsAdmin)
                                {
                                    <th class="py-3 text-center">Actions</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var exam in exams)
                            {
                                <tr class="@(newExam.Id == exam.Id && isEditing ? "table-primary-subtle" : "")">
                                    <td class="ps-4 fw-bold text-dark">@exam.SubjectName</td>
                                    <td><span class="badge bg-light text-dark border fw-semibold">@exam.SubjectCode</span></td>
                                    <td class="text-muted font-monospace">@(exam.ExamDate?.ToString("MMMM dd, yyyy | hh:mm tt") ?? "TBA")</td>
                                    <td><i class="bi bi-geo-alt-fill text-danger me-1"></i> @exam.Room</td>
                                    @if (IsAdmin)
                                    {
                                        <td class="text-center">
                                            <div class="d-flex justify-content-center gap-1">
                                                <button class="btn btn-sm btn-outline-primary btn-actions"
                                                        title="Edit Context"
                                                        @onclick="() => PrepareEditMode(exam)">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                <button class="btn btn-sm btn-outline-danger btn-actions"
                                                        title="Purge Entry"
                                                        @onclick="() => ConfirmDeleteSchedule(exam.Id, exam.SubjectName)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        
        <div class="mt-4 p-3 alert alert-warning border border-warning-subtle d-flex align-items-center gap-3" style="border-radius: 10px;">
            <i class="bi bi-exclamation-octagon-fill text-warning fs-3"></i>
            <small class="text-dark">
                <strong>Important Student Advisory Note:</strong> Please reach the examination hall strictly 15 minutes before the scheduled start time. Bringing your physical printed University ID Card is mandatory.
            </small>
        </div>
    }
</div>

<style>
    .transition-style {
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    }

    .btn-actions {
        border-radius: 6px;
        padding: 4px 8px;
        transition: all 0.2s;
    }

        .btn-actions:hover {
            transform: scale(1.08);
        }
</style>

@code {
    private List<ExamSchedule>? exams;
    private bool showForm = false;
    private bool isEditing = false;
    private ExamSchedule newExam = new ExamSchedule { ExamDate = DateTime.Now };

    private string alertMessage = string.Empty;
    private string alertClass = "success";

    private bool IsAdmin => UserSession.CurrentUser?.Role?.RoleName == "Admin" || UserSession.CurrentUser?.RoleId == 1;

    protected override async Task OnInitializedAsync() => await LoadExams();

    private async Task LoadExams()
    {
        try
        {
            exams = await Repo.GetExamSchedulesAsync();
        }
        catch (Exception ex)
        {
            TriggerNotification($"Data loading exception: {ex.Message}", "danger");
        }
    }

    private void PrepareEditMode(ExamSchedule exam)
    {
        // Pura data editing model me map karenge shallow copy crash prevention ke liye
        newExam = new ExamSchedule
        {
            Id = exam.Id,
            SubjectName = exam.SubjectName,
            SubjectCode = exam.SubjectCode,
            ExamDate = exam.ExamDate,
            Room = exam.Room
        };
        isEditing = true;
        showForm = true;
        TriggerNotification($"Loaded data stream for '{exam.SubjectName}' ready to edit.", "primary");
    }

    private async Task ConfirmDeleteSchedule(int id, string targetName)
    {
        try
        {
            await Repo.DeleteExamScheduleAsync(id);
            TriggerNotification($"Exam configuration record for '{targetName}' permanently dropped.", "success");
            
            // State reset tracking optimization
            if (isEditing && newExam.Id == id) ResetFormState();
            
            await LoadExams();
        }
        catch (Exception ex)
        {
            TriggerNotification($"Pipeline validation error during deletion: {ex.Message}", "danger");
        }
    }

    private async Task SaveExam()
    {
        if (!IsAdmin)
        {
            TriggerNotification("Unauthorized contextual scope context interrupted.", "danger");
            return;
        }

        if (string.IsNullOrWhiteSpace(newExam.SubjectName) || string.IsNullOrWhiteSpace(newExam.SubjectCode))
        {
            TriggerNotification("Subject Name and Code validations mismatch.", "danger");
            return;
        }

        try
        {
            if (isEditing)
            {
                // Update transaction call
                await Repo.UpdateExamScheduleAsync(newExam);
                TriggerNotification($"Exam configurations updated for '{newExam.SubjectName}'!", "success");
            }
            else
            {
                // Core Add tracking call
                await Repo.AddExamScheduleAsync(newExam);
                TriggerNotification($"Successfully registered exam for '{newExam.SubjectName}' into directory structure.", "success");
            }
            
            ResetFormState();
            await LoadExams();
        }
        catch (Exception ex)
        {
            TriggerNotification($"Database synchronization fault: {ex.Message}", "danger");
        }
    }

    private void ToggleFormPanel()
    {
        if (showForm)
        {
            ResetFormState();
        }
        else
        {
            showForm = true;
        }
    }

    private void ResetFormState()
    {
        newExam = new ExamSchedule { ExamDate = DateTime.Now };
        isEditing = false;
        showForm = false;
    }

    private void TriggerNotification(string msg, string type)
    {
        alertMessage = msg;
        alertClass = type;
    }

    private void ClearAlert() => alertMessage = string.Empty;
}