@page "/exams"
@using CampusServicePortal.Data
@using CampusServicePortal.Repositories
@inject ICampusRepository Repo

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">@(IsAdmin ? "Exam Management Portal" : "Exam Schedule")</h2>
        
        @if (IsAdmin)
        {
            <button class="btn btn-danger" @onclick="() => showForm = !showForm">
                <i class="bi bi-plus-circle"></i> @(showForm ? "Close Form" : "Add New Schedule")
            </button>
        }
    </div>

    @* THE HIDDEN FORM (Only shows when Admin clicks the button) *@
    @if (showForm && IsAdmin)
    {
        <div class="card card-body mb-4 shadow-sm border-danger">
            <h5 class="card-title">Add New Exam Entry</h5>
            <div class="row g-3">
                <div class="col-md-3">
                    <input type="text" class="form-control" placeholder="Subject Name" @bind="newExam.SubjectName" />
                </div>
                <div class="col-md-2">
                    <input type="text" class="form-control" placeholder="Code (e.g. CS-101)" @bind="newExam.SubjectCode" />
                </div>
                <div class="col-md-3">
                    <input type="datetime-local" class="form-control" @bind="newExam.ExamDate" />
                </div>
                <div class="col-md-2">
                    <input type="text" class="form-control" placeholder="Room/Venue" @bind="newExam.Room" />
                </div>
                <div class="col-md-2">
                    <button class="btn btn-success w-100" @onclick="SaveExam">Save</button>
                </div>
            </div>
        </div>
    }
    </div>

    @if (exams == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-danger" role="status"></div>
            <p class="mt-2">Fetching examination data...</p>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="@(IsAdmin ? "table-dark" : "table-danger text-white")">
                        <tr>
                            <th class="ps-4">Subject</th>
                            <th>Code</th>
                            <th>Date & Time</th>
                            <th>Venue</th>
                            @if (IsAdmin)
                            {
                                <th>Actions</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var exam in exams)
                        {
                            <tr>
                                <td class="ps-4 fw-bold">@exam.SubjectName</td>
                                <td><span class="badge bg-light text-dark border">@exam.SubjectCode</span></td>
                                <td>@(exam.ExamDate?.ToString("MMMM dd, yyyy | hh:mm tt") ?? "TBA")</td>
                                <td><i class="bi bi-geo-alt text-danger"></i> @exam.Room</td>
                                @if (IsAdmin)
                                {
                                    <td>
                                        <button class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></button>
                                        <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        
        <div class="mt-3 p-3 bg-light rounded border">
            <small class="text-muted">
                <strong>Note:</strong> Please reach the examination hall 15 minutes before the start time.
                Bring your University ID card.
            </small>
        </div>
    }

@code {
    private List<ExamSchedule>? exams;
    private bool showForm = false;
    private ExamSchedule newExam = new ExamSchedule { ExamDate = DateTime.Now };

    private bool IsAdmin => UserSession.CurrentUser?.Role?.RoleName == "Admin" || UserSession.CurrentUser?.RoleId == 1;

    protected override async Task OnInitializedAsync()
    {
        await LoadExams();
    }

    private async Task LoadExams()
    {
        exams = await Repo.GetExamSchedulesAsync();
    }

    private async Task SaveExam()
    {
        if (!string.IsNullOrEmpty(newExam.SubjectName) && !string.IsNullOrEmpty(newExam.SubjectCode))
        {
            await Repo.AddExamScheduleAsync(newExam); // Save to DB
            newExam = new ExamSchedule { ExamDate = DateTime.Now }; // Reset form
            showForm = false; // Hide form
            await LoadExams(); // Refresh table immediately
        }
    }
}