@page "/exams"
@using CampusServicePortal.Data
@using CampusServicePortal.Repositories
@inject ICampusRepository Repo

<div class="container mt-4">
    <div class="d-flex align-items-center mb-4">
        <i class="bi bi-file-earmark-text h2 text-danger me-2"></i>
        <h2 class="fw-bold mb-0">Exam Schedule</h2>
    </div>

    @if (exams == null)
    {
        <div class="text-center">
            <div class="spinner-border text-primary" role="status"></div>
            <p>Loading schedule...</p>
        </div>
    }
    else if (!exams.Any())
    {
        <div class="alert alert-info">No exams are currently scheduled.</div>
    }
    else
    {
        <div class="table-responsive shadow-sm">
            <table class="table table-hover align-middle bg-white">
                <thead class="table-danger">
                    <tr>
                        <th>Subject Code</th>
                        <th>Subject Name</th>
                        <th>Date & Time</th>
                        <th>Room</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var exam in exams)
                    {
                        <tr>
                            <td class="fw-bold">@exam.SubjectCode</td>
                            <td>@exam.SubjectName</td>
                            <td>@(exam.ExamDate.HasValue ? exam.ExamDate.Value.ToString("f") : "TBA")</td>
                            <td><span class="badge bg-secondary">@exam.Room</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<ExamSchedule>? exams;

    protected override async Task OnInitializedAsync()
    {
        exams = await Repo.GetExamSchedulesAsync();
    }
}