@page "/"
@using CampusServicePortal.Data
@inject UserSession Session

<PageTitle>Dashboard Infrastructure</PageTitle>

<div class="workspace-outer">
    <div class="row mb-4 mx-0">
        <div class="col-12 p-0">
            <div class="hero-glass-card text-white d-flex justify-content-between align-items-center flex-wrap gap-4">
                <div>
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <span class="spinner-grow spinner-grow-sm text-info" role="status"></span>
                        <span class="text-info font-monospace text-uppercase small tracking-wider fw-bold">Live Portal Node</span>
                    </div>
                    <h1 class="fw-extrabold display-6 m-0">
                        @(UserSession.CurrentUser?.Role?.RoleName == "Admin" ? "Admin Control Center" : "Student Command Hub")
                    </h1>
                    <p class="text-white-50 m-0 mt-2 fs-6">Access integrated platform microservices, view system metrics, and update profile logs seamlessly.</p>
                </div>
                <div>
                    <span class="badge bg-white bg-opacity-10 text-white border border-white border-opacity-20 px-4 py-3 rounded-pill fs-6 fw-bold">
                        <i class="bi bi-person-fill me-2"></i> @(UserSession.CurrentUser?.FullName ?? "Guest Account")
                    </span>
                </div>
            </div>
        </div>
    </div>

    @if (UserSession.CurrentUser?.Role?.RoleName == "Admin" || UserSession.CurrentUser?.RoleId == 1)
    {
        <div class="row g-4 mx-0">
            <div class="col-12 col-md-6 col-xl-3 p-0 pe-md-3 pb-2">
                <div class="metric-pill-card">
                    <div>
                        <span class="text-muted font-monospace text-uppercase small fw-bold">Enrolled Base</span>
                        <h3 class="fw-bold text-dark m-0 mt-1">150 Users</h3>
                    </div>
                    <div class="icon-container bg-primary bg-opacity-10 text-primary">
                        <i class="bi bi-people-fill fs-3"></i>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-xl-3 p-0 pe-xl-3 pb-2">
                <div class="metric-pill-card">
                    <div>
                        <span class="text-muted font-monospace text-uppercase small fw-bold">Academic Blocks</span>
                        <h3 class="fw-bold text-dark m-0 mt-1">12 Catalogs</h3>
                    </div>
                    <div class="icon-container bg-success bg-opacity-10 text-success">
                        <i class="bi bi-journal-bookmark-fill fs-3"></i>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-xl-3 p-0 pe-md-3 pb-2">
                <div class="metric-pill-card">
                    <div>
                        <span class="text-muted font-monospace text-uppercase small fw-bold">Open Tickets</span>
                        <h3 class="fw-bold text-danger m-0 mt-1">5 Pending</h3>
                    </div>
                    <div class="icon-container bg-danger bg-opacity-10 text-danger">
                        <i class="bi bi-envelope-exclamation-fill fs-3"></i>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-xl-3 p-0 pb-2">
                <div class="metric-pill-card">
                    <div>
                        <span class="text-muted font-monospace text-uppercase small fw-bold">System Integrity</span>
                        <h3 class="fw-bold text-info m-0 mt-1">Healthy</h3>
                    </div>
                    <div class="icon-container bg-info bg-opacity-10 text-info">
                        <i class="bi bi-cpu-fill fs-3"></i>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4 mx-0">
            <div class="col-12 col-lg-8 p-0 pe-lg-4 mb-3">
                <div class="card board-card h-100">
                    <div class="card-header board-header d-flex align-items-center">
                        <i class="bi bi-bell-fill text-primary me-2.5 fs-5"></i>
                        <h5 class="m-0 fw-bold text-dark">Verified Campus Information Boards</h5>
                    </div>
                    <div class="card-body p-4 d-flex flex-column gap-3">
                        
                        <div class="p-3 rounded border-start border-4 border-danger" style="background: #FFF5F5;">
                            <div class="d-flex justify-content-between align-items-center mb-1 flex-wrap gap-2">
                                <h6 class="fw-bold text-dark m-0">Fall 2024 Exam Timetables Published</h6>
                                <span class="bulletin-badge-critical">Critical</span>
                            </div>
                            <p class="text-secondary small m-0">The complete examination matrix has been approved. Access the Exam Schedules view to review target timelines and hall locations.</p>
                        </div>

                        <div class="p-3 rounded border-start border-4 border-primary" style="background: #F0F9FF;">
                            <div class="d-flex justify-content-between align-items-center mb-1 flex-wrap gap-2">
                                <h6 class="fw-bold text-dark m-0">New Bus Transit Core Routes Active</h6>
                                <span class="bulletin-badge-info">Transit</span>
                            </div>
                            <p class="text-secondary small m-0">Institutional transit fleet capacities have been increased for South City corridors during peak hours. Real-time updates are available in the logistics tab.</p>
                        </div>

                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-4 p-0 mb-3">
                <div class="card board-card h-100">
                    <div class="card-header board-header">
                        <h5 class="m-0 fw-bold text-dark"><i class="bi bi-lightning-charge-fill text-warning me-2"></i>Quick Options</h5>
                    </div>
                    <div class="card-body p-4 d-flex flex-column gap-3">
                        
                        <a href="courses" class="action-shortcut">
                            <div class="bg-primary bg-opacity-10 text-primary p-2.5 rounded-3 me-3">
                                <i class="bi bi-collection-play-fill fs-4"></i>
                            </div>
                            <div>
                                <div class="fw-bold text-dark">My Enrollments</div>
                                <small class="text-muted">Review current registered degree tracks</small>
                            </div>
                        </a>

                        <a href="transport" class="action-shortcut">
                            <div class="bg-success bg-opacity-10 text-success p-2.5 rounded-3 me-3">
                                <i class="bi bi-map-fill fs-4"></i>
                            </div>
                            <div>
                                <div class="fw-bold text-dark">Check Bus Status</div>
                                <small class="text-muted">Track campus transport deployment details</small>
                            </div>
                        </a>

                    </div>
                </div>
            </div>
        </div>
    }
</div>