@page "/"
@using CampusServicePortal.Data
@inject UserSession Session

<PageTitle>Dashboard</PageTitle>

<div class="container-fluid px-4 py-4 bg-light min-vh-100">
    
    @* MODERN TOP GREETING CARD *@
    <div class="row mb-4">
        <div class="col-12">
            <div class="p-4 bg-white rounded-3 shadow-sm border border-0 d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div>
                    <h1 class="fw-extrabold text-dark mb-1">
                        @((UserSession.CurrentUser?.Role?.RoleName == "Admin") ? "Admin Control Center" : "Student Hub")
                    </h1>
                    <p class="text-muted mb-0">Welcome back! Here's a complete status report of your institutional profile data.</p>
                </div>
                <div>
                    <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 fs-6 rounded-pill border border-primary border-opacity-20">
                        <i class="bi bi-person-check-fill me-1"></i> @(UserSession.CurrentUser?.FullName ?? "Guest Account")
                    </span>
                </div>
            </div>
        </div>
    </div>

    @if (UserSession.CurrentUser?.Role?.RoleName == "Admin" || UserSession.CurrentUser?.RoleId == 1)
    {
        @* ADMIN MATRIX PANELS (With border status markers and modern icons) *@
        <div class="row g-4">
            <div class="col-xl-3 col-sm-6">
                <div class="card border-0 shadow-sm rounded-3 overflow-hidden border-start border-4 border-primary bg-white h-100">
                    <div class="card-body d-flex align-items-center justify-content-between p-4">
                        <div>
                            <h6 class="text-muted text-uppercase small font-monospace mb-2">Total Registry</h6>
                            <h2 class="fw-bold text-dark mb-0">150 Students</h2>
                        </div>
                        <div class="bg-primary bg-opacity-10 p-3 rounded-3 text-primary">
                            <i class="bi bi-people-fill fs-3"></i>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-xl-3 col-sm-6">
                <div class="card border-0 shadow-sm rounded-3 overflow-hidden border-start border-4 border-success bg-white h-100">
                    <div class="card-body d-flex align-items-center justify-content-between p-4">
                        <div>
                            <h6 class="text-muted text-uppercase small font-monospace mb-2">Course Portals</h6>
                            <h2 class="fw-bold text-dark mb-0">12 Catalogued</h2>
                        </div>
                        <div class="bg-success bg-opacity-10 p-3 rounded-3 text-success">
                            <i class="bi bi-journal-text fs-3"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-3 col-sm-6">
                <div class="card border-0 shadow-sm rounded-3 overflow-hidden border-start border-4 border-warning bg-white h-100">
                    <div class="card-body d-flex align-items-center justify-content-between p-4">
                        <div>
                            <h6 class="text-muted text-uppercase small font-monospace mb-2">Helpdesk Queue</h6>
                            <h2 class="fw-bold text-dark mb-0">5 Pending</h2>
                        </div>
                        <div class="bg-warning bg-opacity-10 p-3 rounded-3 text-warning">
                            <i class="bi bi-chat-left-dots-fill fs-3"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-3 col-sm-6">
                <div class="card border-0 shadow-sm rounded-3 overflow-hidden border-start border-4 border-info bg-white h-100">
                    <div class="card-body d-flex align-items-center justify-content-between p-4">
                        <div>
                            <h6 class="text-muted text-uppercase small font-monospace mb-2">Audits & Logs</h6>
                            <h2 class="fw-bold text-dark mb-0">System Live</h2>
                        </div>
                        <div class="bg-info bg-opacity-10 p-3 rounded-3 text-info">
                            <i class="bi bi-terminal-dash fs-3"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        @* STUDENT DASHBOARD *@
        <div class="row g-4">
            
            @* BULLETIN PANEL *@
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm rounded-3 bg-white h-100">
                    <div class="card-header bg-white py-3 border-bottom d-flex align-items-center">
                        <i class="bi bi-megaphone-fill text-danger me-2 fs-5"></i>
                        <h5 class="card-title fw-bold text-dark mb-0">Live Bulletins & Announcements</h5>
                    </div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush rounded-bottom">
                            <div class="list-group-item p-3 border-0 border-bottom bg-transparent">
                                <div class="d-flex w-100 justify-content-between mb-1">
                                    <h6 class="fw-bold text-dark mb-0">📅 Exam Schedule Released</h6>
                                    <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill">Important</span>
                                </div>
                                <p class="text-muted small mb-0">The full exam timetable for the Fall semester has been formally updated in your portal track.</p>
                            </div>
                            <div class="list-group-item p-3 border-0 bg-transparent">
                                <div class="d-flex w-100 justify-content-between mb-1">
                                    <h6 class="fw-bold text-dark mb-0">🚌 New Bus Service Fleet Added</h6>
                                    <span class="badge bg-success bg-opacity-10 text-success rounded-pill">Transit</span>
                                </div>
                                <p class="text-muted small mb-0">An additional transit line is active servicing the South City routes. Secure your slot details.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            @* QUICK ACTION UTILITIES DOCK *@
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm rounded-3 bg-white h-100">
                    <div class="card-header bg-white py-3 border-bottom">
                        <h5 class="card-title fw-bold text-dark mb-0"><i class="bi bi-lightning-charge-fill text-warning me-2"></i>Workspace Utilities</h5>
                    </div>
                    <div class="card-body p-4 d-flex flex-column gap-3 justify-content-center">
                        <a href="courses" class="btn btn-outline-primary d-flex align-items-center p-3 rounded-3 text-start w-100 border shadow-none bg-light bg-opacity-20 hover-card">
                            <div class="bg-primary bg-opacity-10 p-2 rounded-3 text-primary me-3"><i class="bi bi-journal-check fs-4"></i></div>
                            <div>
                                <div class="fw-bold text-dark">My Enrollments</div>
                                <small class="text-muted text-wrap">Check active core curricula courses</small>
                            </div>
                        </a>
                        
                        <a href="transport" class="btn btn-outline-success d-flex align-items-center p-3 rounded-3 text-start w-100 border shadow-none bg-light bg-opacity-20 hover-card">
                            <div class="bg-success bg-opacity-10 p-2 rounded-3 text-success me-3"><i class="bi bi-bus-front-fill fs-4"></i></div>
                            <div>
                                <div class="fw-bold text-dark">Check Bus Status</div>
                                <small class="text-muted text-wrap">Track active routes and vehicle locations</small>
                            </div>
                        </a>
                    </div>
                </div>
            </div>

        </div>
    }
</div>