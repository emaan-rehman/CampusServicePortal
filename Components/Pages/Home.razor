@page "/"
@using CampusServicePortal.Data
@inject UserSession Session

<PageTitle>Dashboard</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold">@((UserSession.CurrentUser?.Role?.RoleName == "Admin") ? "Admin Control Center" : "Student Dashboard")</h1>
        <span class="badge bg-primary p-2">Welcome, @UserSession.CurrentUser?.FullName</span>
    </div>

    @if (UserSession.CurrentUser?.Role?.RoleName == "Admin" || UserSession.CurrentUser?.RoleId == 1)
    {
        @* ADMIN VIEW: Statistics and Management Cards *@
        <div class="row g-4">
            <div class="col-md-3">
                <div class="card bg-primary text-white shadow">
                    <div class="card-body text-center">
                        <h3>150</h3>
                        <p>Total Students</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-success text-white shadow">
                    <div class="card-body text-center">
                        <h3>12</h3>
                        <p>Active Courses</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-warning text-dark shadow">
                    <div class="card-body text-center">
                        <h3>5</h3>
                        <p>Pending Complaints</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-info text-white shadow">
                    <div class="card-body text-center">
                        <h3>View Logs</h3>
                        <p>System Activity</p>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        @* STUDENT VIEW: Personal Quick Actions *@
        <div class="row g-4">
            <div class="col-md-8">
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-white fw-bold">Recent Announcements</div>
                    <div class="card-body">
                        <ul class="list-unstyled">
                            <li class="mb-2 border-bottom pb-2">📢 Exam schedule for Fall 2024 has been posted.</li>
                            <li class="mb-2">📢 New bus route added for South City.</li>
                        </ul>
                    </div>
                </div>
            </div>
            
            <div class="col-md-4">
                <div class="card border-primary mb-3">
                    <div class="card-body">
                        <h5 class="card-title fw-bold">Quick Links</h5>
                        <div class="d-grid gap-2">
                            <a href="courses" class="btn btn-outline-primary text-start">My Enrollments</a>
                            <a href="transport" class="btn btn-outline-primary text-start">Check Bus Status</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>