@page "/"
@using CampusServicePortal.Data
@inject UserSession Session

<PageTitle>Dashboard Infrastructure</PageTitle>

<div class="dashboard-viewport container-fluid px-4 py-4">
    
    @* PRIMARY MANAGEMENT HERO PROFILE *@
    <div class="row mb-4">
        <div class="col-12">
            <div class="hero-banner-card p-4 rounded-3 shadow-sm border-0 d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div class="hero-text">
                    <h1 class="fw-black text-navy display-6 mb-1">
                        @((UserSession.CurrentUser?.Role?.RoleName == "Admin") ? "Admin Control Center" : "Student Command Hub")
                    </h1>
                    <p class="text-secondary mb-0">System services operating securely. Access all integrated modules below.</p>
                </div>
                <div class="hero-pill">
                    <span class="badge badge-premium px-4 py-2.5 fs-6 rounded-pill">
                        <i class="bi bi-person-circle text-primary me-2"></i> @(UserSession.CurrentUser?.FullName ?? "Guest Profile")
                    </span>
                </div>
            </div>
        </div>
    </div>

    @if (UserSession.CurrentUser?.Role?.RoleName == "Admin" || UserSession.CurrentUser?.RoleId == 1)
    {
        @* ANALYTICS GRID *@
        <div class="row g-4">
            <div class="col-xl-3 col-sm-6">
                <div class="card metric-card border-0 shadow-sm rounded-3 overflow-hidden border-start border-5 border-primary h-100">
                    <div class="card-body d-flex align-items-center justify-content-between p-4">
                        <div>
                            <h6 class="text-secondary text-uppercase small tracking-wider font-monospace mb-2">Enrolled Users</h6>
                            <h2 class="fw-black text-navy mb-0">150</h2>
                        </div>
                        <div class="icon-blob bg-primary-soft text-primary p-3 rounded-3">
                            <i class="bi bi-people-fill fs-3"></i>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-xl-3 col-sm-6">
                <div class="card metric-card border-0 shadow-sm rounded-3 overflow-hidden border-start border-5 border-info h-100">
                    <div class="card-body d-flex align-items-center justify-content-between p-4">
                        <div>
                            <h6 class="text-secondary text-uppercase small tracking-wider font-monospace mb-2">Curriculum Blocks</h6>
                            <h2 class="fw-black text-navy mb-0">12 Active</h2>
                        </div>
                        <div class="icon-blob bg-info-soft text-info p-3 rounded-3">
                            <i class="bi bi-journal-code fs-3"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-3 col-sm-6">
                <div class="card metric-card border-0 shadow-sm rounded-3 overflow-hidden border-start border-5 border-warning h-100">
                    <div class="card-body d-flex align-items-center justify-content-between p-4">
                        <div>
                            <h6 class="text-secondary text-uppercase small tracking-wider font-monospace mb-2">Open Discrepancies</h6>
                            <h2 class="fw-black text-navy mb-0">5 Alerts</h2>
                        </div>
                        <div class="icon-blob bg-warning-soft text-warning p-3 rounded-3">
                            <i class="bi bi-envelope-exclamation-fill fs-3"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-3 col-sm-6">
                <div class="card metric-card border-0 shadow-sm rounded-3 overflow-hidden border-start border-5 border-success h-100">
                    <div class="card-body d-flex align-items-center justify-content-between p-4">
                        <div>
                            <h6 class="text-secondary text-uppercase small tracking-wider font-monospace mb-2">System Engines</h6>
                            <h2 class="fw-black text-success mb-0">Live Audit</h2>
                        </div>
                        <div class="icon-blob bg-success-soft text-success p-3 rounded-3">
                            <i class="bi bi-cpu-fill fs-3"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        @* ASYMMETRIC VISUAL STUDENT INTERFACES *@
        <div class="row g-4">
            
            @* DISPATCH AND ANNOUNCEMENT FEED *@
            <div class="col-lg-8">
                <div class="card content-panel-card border-0 shadow-sm rounded-3 bg-white h-100">
                    <div class="card-header bg-white border-bottom py-3 d-flex align-items-center justify-content-between px-4">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-shield-shaded text-primary me-2.5 fs-5"></i>
                            <h5 class="card-title fw-black text-navy mb-0">Verified Institutional Bulletins</h5>
                        </div>
                        <span class="badge bg-light text-primary border border-primary-soft rounded-pill font-monospace px-2.5 py-1">Synced</span>
                    </div>
                    <div class="card-body p-0">
                        <div class="bulletin-feed-container">
                            <div class="bulletin-row p-4 border-bottom position-relative">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h6 class="fw-bold text-navy mb-0">Fall Timetables Published</h6>
                                    <span class="badge badge-alert rounded-pill">Urgent</span>
                                </div>
                                <p class="text-secondary small mb-0">The full examination matrix has been successfully processed. Check details under the Examination tab.</p>
                            </div>
                            <div class="bulletin-row p-4 position-relative">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h6 class="fw-bold text-navy mb-0">Transit Routes Updated</h6>
                                    <span class="badge badge-info rounded-pill">Transit</span>
                                </div>
                                <p class="text-secondary small mb-0">An additional transit fleet servicing South City lines has been allocated for peak operation hours.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            @* QUICK UTILITY LINKS *@
            <div class="col-lg-4">
                <div class="card content-panel-card border-0 shadow-sm rounded-3 bg-white h-100">
                    <div class="card-header bg-white border-bottom py-3 px-4">
                        <h5 class="card-title fw-black text-navy mb-0"><i class="bi bi-lightning-charge-fill text-warning me-2"></i>Workspace Shortcuts</h5>
                    </div>
                    <div class="card-body p-4 d-flex flex-column gap-3 justify-content-start">
                        <a href="courses" class="quick-nav-action-card d-flex align-items-center p-3 rounded-3 text-start border bg-light bg-opacity-20 text-decoration-none transition-all">
                            <div class="bg-primary-soft p-2.5 rounded-3 text-primary me-3"><i class="bi bi-file-earmark-code-fill fs-4"></i></div>
                            <div>
                                <div class="fw-bold text-navy mb-0">My Enrollments</div>
                                <small class="text-secondary text-wrap d-block">Manage active degree streams</small>
                            </div>
                        </a>
                        
                        <a href="transport" class="quick-nav-action-card d-flex align-items-center p-3 rounded-3 text-start border bg-light bg-opacity-20 text-decoration-none transition-all">
                            <div class="bg-success-soft p-2.5 rounded-3 text-success me-3"><i class="bi bi-geo-alt-fill fs-4"></i></div>
                            <div>
                                <div class="fw-bold text-navy mb-0">Check Bus Status</div>
                                <small class="text-secondary text-wrap d-block">Track shuttle deployments</small>
                            </div>
                        </a>
                    </div>
                </div>
            </div>

        </div>
    }
</div>