@page "/"
@using CampusServicePortal.Data
@inject UserSession Session

<PageTitle>Portal Core Dashboard</PageTitle>

<div class="container-fluid p-3 p-md-4" style="background-color: #f4f7fe; min-height: 100vh; font-family: system-ui, -apple-system, sans-serif;">
    <div class="row g-4">
        
        <div class="col-12 col-md-4 col-xl-3">
            <div class="shadow" style="background-color: #0A192F; border-radius: 16px; overflow: hidden; min-height: calc(100vh - 2rem);">
                <NavMenu />
            </div>
        </div>

        <div class="col-12 col-md-8 col-xl-9">
            <div class="d-flex flex-column gap-4">

                <div class="p-4 p-md-5 text-white shadow-sm d-flex justify-content-between align-items-center flex-wrap gap-4" style="background: linear-gradient(135deg, #1E3A8A 0%, #0F172A 100%); border-radius: 16px;">
                    <div>
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <span class="spinner-grow spinner-grow-sm text-info" style="animation-duration: 1.5s;"></span>
                            <span class="text-info font-monospace text-uppercase small tracking-wider fw-bold" style="font-size: 0.75rem;">Secure Network Node</span>
                        </div>
                        <h1 class="fw-bold m-0 text-white" style="font-size: 1.75rem;">
                            @(UserSession.CurrentUser?.Role?.RoleName == "Admin" ? "Administrative Control Panel" : "Student Command Hub")
                        </h1>
                        <p class="text-white-50 m-0 mt-2" style="max-width: 600px; font-size: 0.9rem;">Access your central core campus microservices, check updated real-time logs, and monitor your university profiles securely.</p>
                    </div>
                    <div>
                        <span class="badge bg-white bg-opacity-10 border border-white border-opacity-25 px-4 py-3 rounded-pill fs-6 fw-semibold text-white">
                            <i class="bi bi-person-circle text-info me-2"></i> @(UserSession.CurrentUser?.FullName ?? "Guest Profile")
                        </span>
                    </div>
                </div>

                @if (UserSession.CurrentUser?.Role?.RoleName == "Admin" || UserSession.CurrentUser?.RoleId == 1)
                {
                    <div class="row g-4">
                        <div class="col-12 col-sm-6 col-xl-3">
                            <div class="bg-white p-4 rounded-4 border d-flex align-items-center justify-content-between shadow-sm" style="border-radius: 14px;">
                                <div>
                                    <small class="text-muted text-uppercase font-monospace fw-bold" style="font-size: 0.7rem;">System Base</small>
                                    <h3 class="fw-bold m-0 mt-1 text-dark" style="font-size: 1.35rem;">150 Users</h3>
                                </div>
                                <div class="rounded-3 d-flex align-items-center justify-content-center" style="width: 48px; height: 48px; background-color: #eff6ff; color: #2563eb; border-radius: 10px;"><i class="bi bi-people-fill fs-4"></i></div>
                            </div>
                        </div>
                        <div class="col-12 col-sm-6 col-xl-3">
                            <div class="bg-white p-4 rounded-4 border d-flex align-items-center justify-content-between shadow-sm" style="border-radius: 14px;">
                                <div>
                                    <small class="text-muted text-uppercase font-monospace fw-bold" style="font-size: 0.7rem;">Active Services</small>
                                    <h3 class="fw-bold m-0 mt-1 text-dark" style="font-size: 1.35rem;">12 Nodes</h3>
                                </div>
                                <div class="rounded-3 d-flex align-items-center justify-content-center" style="width: 48px; height: 48px; background-color: #ecfdf5; color: #10b981; border-radius: 10px;"><i class="bi bi-cpu fs-4"></i></div>
                            </div>
                        </div>
                        <div class="col-12 col-sm-6 col-xl-3">
                            <div class="bg-white p-4 rounded-4 border d-flex align-items-center justify-content-between shadow-sm" style="border-radius: 14px;">
                                <div>
                                    <small class="text-muted text-uppercase font-monospace fw-bold" style="font-size: 0.7rem;">Pending Tickets</small>
                                    <h3 class="fw-bold m-0 mt-1 text-danger" style="font-size: 1.35rem;">5 Alerts</h3>
                                </div>
                                <div class="rounded-3 d-flex align-items-center justify-content-center" style="width: 48px; height: 48px; background-color: #fef2f2; color: #ef4444; border-radius: 10px;"><i class="bi bi-envelope-exclamation-fill fs-4"></i></div>
                            </div>
                        </div>
                        <div class="col-12 col-sm-6 col-xl-3">
                            <div class="bg-white p-4 rounded-4 border d-flex align-items-center justify-content-between shadow-sm" style="border-radius: 14px;">
                                <div>
                                    <small class="text-muted text-uppercase font-monospace fw-bold" style="font-size: 0.7rem;">Database Core</small>
                                    <h3 class="fw-bold m-0 mt-1 text-success" style="font-size: 1.35rem;">Online</h3>
                                </div>
                                <div class="rounded-3 d-flex align-items-center justify-content-center" style="width: 48px; height: 48px; background-color: #f0fdf4; color: #16a34a; border-radius: 10px;"><i class="bi bi-shield-check-fill fs-4"></i></div>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="row g-4">
                        <div class="col-12 col-xl-8">
                            <div class="card bg-white border-0 shadow-sm h-100 overflow-hidden" style="border-radius: 16px;">
                                <div class="card-header bg-white px-4 py-3 border-bottom d-flex align-items-center gap-2">
                                    <i class="bi bi-bell-fill text-primary fs-5"></i>
                                    <h5 class="m-0 fw-bold text-dark" style="font-size: 1rem;">Institutional Information Bulletin</h5>
                                </div>
                                <div class="card-body p-4 d-flex flex-column gap-3">
                                    
                                    <div class="p-3 border-start border-4 border-danger rounded shadow-sm" style="background-color: #fff5f5; border-radius: 8px;">
                                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-2">
                                            <h6 class="fw-bold text-dark m-0" style="font-size: 0.95rem;">Fall 2024 Exam Timetables Published</h6>
                                            <span class="badge bg-danger bg-opacity-10 text-danger px-2.5 py-1.5 rounded-pill font-monospace small" style="font-size: 0.7rem;">CRITICAL</span>
                                        </div>
                                        <p class="text-secondary m-0" style="font-size: 0.85rem; line-height: 1.5;">The complete unified examination matrix has been confirmed. Review targets, venue coordinates, and student seat codes immediately.</p>
                                    </div>

                                    <div class="p-3 border-start border-4 border-primary rounded shadow-sm" style="background-color: #f0f9ff; border-radius: 8px;">
                                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-2">
                                            <h6 class="fw-bold text-dark m-0" style="font-size: 0.95rem;">Transit Logistics Corridor Extensions</h6>
                                            <span class="badge bg-primary bg-opacity-10 text-primary px-2.5 py-1.5 rounded-pill font-monospace small" style="font-size: 0.7rem;">LOGISTICS</span>
                                        </div>
                                        <p class="text-secondary m-0" style="font-size: 0.85rem; line-height: 1.5;">Shuttle vehicle deployment capacity counts have been doubled along major suburban lanes for rush hour commuters.</p>
                                    </div>

                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-xl-4">
                            <div class="card bg-white border-0 shadow-sm h-100 overflow-hidden" style="border-radius: 16px;">
                                <div class="card-header bg-white px-4 py-3 border-bottom">
                                    <h5 class="m-0 fw-bold text-dark" style="font-size: 1rem;"><i class="bi bi-lightning-charge-fill text-warning me-1"></i>Quick System Actions</h5>
                                </div>
                                <div class="card-body p-4 d-flex flex-column gap-3">
                                    
                                    <a href="courses" class="d-flex align-items-center p-3 border rounded-3 text-decoration-none bg-light bg-opacity-50" style="color: inherit; border-radius: 12px; border-color: #e5e7eb; transition: all 0.2s;" onmouseover="this.style.borderColor='#0284c7'; this.style.backgroundColor='#f0f9ff';" onmouseout="this.style.borderColor='#e5e7eb'; this.style.backgroundColor='rgba(248,249,250,0.5)';">
                                        <div class="rounded-3 d-flex align-items-center justify-content-center me-3" style="width: 44px; height: 44px; background-color: #eff6ff; color: #2563eb; min-width:44px; border-radius: 8px;"><i class="bi bi-collection-play-fill fs-5"></i></div>
                                        <div>
                                            <div class="fw-bold text-dark" style="font-size: 0.88rem;">My Academic Records</div>
                                            <span class="text-muted d-block mt-0.5" style="font-size: 0.75rem;">Manage and review current classes</span>
                                        </div>
                                    </a>

                                    <a href="transport" class="d-flex align-items-center p-3 border rounded-3 text-decoration-none bg-light bg-opacity-50" style="color: inherit; border-radius: 12px; border-color: #e5e7eb; transition: all 0.2s;" onmouseover="this.style.borderColor='#10b981'; this.style.backgroundColor='#ecfdf5';" onmouseout="this.style.borderColor='#e5e7eb'; this.style.backgroundColor='rgba(248,249,250,0.5)';">
                                        <div class="rounded-3 d-flex align-items-center justify-content-center me-3" style="width: 44px; height: 44px; background-color: #ecfdf5; color: #10b981; min-width:44px; border-radius: 8px;"><i class="bi bi-map-fill fs-5"></i></div>
                                        <div>
                                            <div class="fw-bold text-dark" style="font-size: 0.88rem;">Transit Tracker</div>
                                            <span class="text-muted d-block mt-0.5" style="font-size: 0.75rem;">Check vehicle deployment updates</span>
                                        </div>
                                    </a>

                                </div>
                            </div>
                        </div>
                    </div>
                }

            </div>
        </div>

    </div>
</div>