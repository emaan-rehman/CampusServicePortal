@page "/"
@using CampusServicePortal.Data
@inject UserSession Session

<PageTitle>Portal Core Dashboard</PageTitle>

<div class="container-fluid p-0">
    
    <div class="row mb-4">
        <div class="col-12">
            <div class="p-4 p-md-5 text-white d-flex justify-content-between align-items-center flex-wrap gap-4 shadow-sm" style="background: linear-gradient(135deg, #0F172A 0%, #1E293B 100%); border-radius: 16px; border: 1px solid rgba(255, 255, 255, 0.08);">
                <div>
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <span class="spinner-grow spinner-grow-sm text-info" style="animation-duration: 1.5s; width: 8px; height: 8px;"></span>
                        <span class="text-info font-monospace text-uppercase fw-bold tracking-wider" style="font-size: 0.725rem; letter-spacing: 1px;">Secure Network Node</span>
                    </div>
                    <h1 class="fw-bold m-0 text-white tracking-tight" style="font-size: 1.85rem;">
                        @(UserSession.CurrentUser?.Role?.RoleName == "Admin" ? "Administrative Control Panel" : "Student Service Portal")
                    </h1>
                    <p class="text-white-50 m-0 mt-2" style="max-width: 650px; font-size: 0.95rem; line-height: 1.6;">
                        Access your central core campus microservices, check updated real-time logs, and monitor your university profiles securely.
                    </p>
                </div>
                <div>
                    <span class="badge bg-white bg-opacity-10 border border-white border-opacity-25 px-4 py-3 rounded-pill fs-6 fw-semibold text-white shadow-sm d-inline-flex align-items-center">
                        <i class="bi bi-person-circle text-info me-2 fs-5"></i> @(UserSession.CurrentUser?.FullName ?? "Guest Profile")
                    </span>
                </div>
            </div>
        </div>
    </div>

    @if (UserSession.CurrentUser?.Role?.RoleName == "Admin" || UserSession.CurrentUser?.RoleId == 1)
    {
        @* --- 🌟 CHANGER: Changed to a 2x2 grid (col-md-6) and increased padding/height for a stronger vertical structure --- *@
        <div class="row g-4">
            
            @* Card 1: System Base *@
            <div class="col-12 col-md-6">
                <div class="bg-white p-4 d-flex align-items-center justify-content-between shadow-sm stats-card-vertical" style="border-radius: 16px; border: 1px solid #E2E8F0; min-height: 120px;">
                    <div>
                        <small class="text-muted text-uppercase font-monospace fw-bold" style="font-size: 0.75rem; letter-spacing: 0.5px;">System Base</small>
                        <h3 class="fw-bold m-0 mt-2 text-dark" style="font-size: 1.75rem;">150 Users</h3>
                    </div>
                    <div class="d-flex align-items-center justify-content-center shadow-inner" style="width: 60px; height: 60px; background-color: #EFF6FF; color: #2563EB; border-radius: 14px;">
                        <i class="bi bi-people-fill fs-3"></i>
                    </div>
                </div>
            </div>
            
            @* Card 2: Active Services *@
            <div class="col-12 col-md-6">
                <div class="bg-white p-4 d-flex align-items-center justify-content-between shadow-sm stats-card-vertical" style="border-radius: 16px; border: 1px solid #E2E8F0; min-height: 120px;">
                    <div>
                        <small class="text-muted text-uppercase font-monospace fw-bold" style="font-size: 0.75rem; letter-spacing: 0.5px;">Active Services</small>
                        <h3 class="fw-bold m-0 mt-2 text-dark" style="font-size: 1.75rem;">12 Nodes</h3>
                    </div>
                    <div class="d-flex align-items-center justify-content-center shadow-inner" style="width: 60px; height: 60px; background-color: #ECFDF5; color: #10B981; border-radius: 14px;">
                        <i class="bi bi-cpu fs-3"></i>
                    </div>
                </div>
            </div>
            
            @* Card 3: Pending Tickets *@
            <div class="col-12 col-md-6">
                <div class="bg-white p-4 d-flex align-items-center justify-content-between shadow-sm stats-card-vertical" style="border-radius: 16px; border: 1px solid #E2E8F0; min-height: 120px;">
                    <div>
                        <small class="text-muted text-uppercase font-monospace fw-bold" style="font-size: 0.75rem; letter-spacing: 0.5px;">Pending Tickets</small>
                        <h3 class="fw-bold m-0 mt-2 text-danger" style="font-size: 1.75rem;">5 Alerts</h3>
                    </div>
                    <div class="d-flex align-items-center justify-content-center shadow-inner" style="width: 60px; height: 60px; background-color: #FEF2F2; color: #EF4444; border-radius: 14px;">
                        <i class="bi bi-envelope-exclamation-fill fs-3"></i>
                    </div>
                </div>
            </div>
            
            @* Card 4: Database Core *@
            <div class="col-12 col-md-6">
                <div class="bg-white p-4 d-flex align-items-center justify-content-between shadow-sm stats-card-vertical" style="border-radius: 16px; border: 1px solid #E2E8F0; min-height: 120px;">
                    <div>
                        <small class="text-muted text-uppercase font-monospace fw-bold" style="font-size: 0.75rem; letter-spacing: 0.5px;">Database Core</small>
                        <h3 class="fw-bold m-0 mt-2 text-success" style="font-size: 1.75rem;">Online</h3>
                    </div>
                    <div class="d-flex align-items-center justify-content-center shadow-inner" style="width: 60px; height: 60px; background-color: #F0FDF4; color: #16A34A; border-radius: 14px;">
                        <i class="bi bi-shield-check-fill fs-3"></i>
                    </div>
                </div>
            </div>

        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-12 col-lg-8">
                <div class="card bg-white shadow-sm h-100 overflow-hidden" style="border-radius: 16px; border: 1px solid #E2E8F0;">
                    <div class="card-header bg-white px-4 py-3 border-bottom d-flex align-items-center gap-2" style="border-bottom: 1px solid #F1F5F9 !important;">
                        <i class="bi bi-bell-fill text-primary fs-5"></i>
                        <h5 class="m-0 fw-bold text-dark" style="font-size: 1.05rem;">Verified Institutional Information Bulletin</h5>
                    </div>
                    <div class="card-body p-4 d-flex flex-column gap-3">
                        
                        <div class="p-3 border-start border-4 border-danger rounded shadow-sm" style="background-color: #FFF5F5; border-radius: 8px;">
                            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-2">
                                <h6 class="fw-bold text-dark m-0" style="font-size: 0.95rem;">Fall 2024 Exam Timetables Published</h6>
                                <span class="badge bg-danger bg-opacity-10 text-danger px-3 py-1.5 rounded-pill font-monospace fw-bold" style="font-size: 0.7rem;">CRITICAL</span>
                            </div>
                            <p class="text-secondary m-0" style="font-size: 0.85rem; line-height: 1.5;">The complete unified examination matrix has been confirmed. Review targets, venue coordinates, and student seat codes immediately.</p>
                        </div>

                        <div class="p-3 border-start border-4 border-primary rounded shadow-sm" style="background-color: #F0F9FF; border-radius: 8px;">
                            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-2">
                                <h6 class="fw-bold text-dark m-0" style="font-size: 0.95rem;">Transit Logistics Corridor Extensions</h6>
                                <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-1.5 rounded-pill font-monospace fw-bold" style="font-size: 0.7rem;">LOGISTICS</span>
                            </div>
                            <p class="text-secondary m-0" style="font-size: 0.85rem; line-height: 1.5;">Shuttle vehicle deployment capacity counts have been doubled along major suburban lanes for rush hour commuters.</p>
                        </div>

                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-4">
                <div class="card bg-white shadow-sm h-100 overflow-hidden" style="border-radius: 16px; border: 1px solid #E2E8F0;">
                    <div class="card-header bg-white px-4 py-3 border-bottom" style="border-bottom: 1px solid #F1F5F9 !important;">
                        <h5 class="m-0 fw-bold text-dark" style="font-size: 1.05rem;"><i class="bi bi-lightning-charge-fill text-warning me-1"></i>Quick System Actions</h5>
                    </div>
                    <div class="card-body p-4 d-flex flex-column gap-3">
                        
                        <a href="courses" class="d-flex align-items-center p-3 text-decoration-none bg-light bg-opacity-50 interactive-action-card" style="color: inherit; border-radius: 12px;">
                            <div class="d-flex align-items-center justify-content-center me-3" style="width: 44px; height: 44px; background-color: #EFF6FF; color: #2563EB; min-width:44px; border-radius: 10px;"><i class="bi bi-collection-play-fill fs-5"></i></div>
                            <div>
                                <div class="fw-bold text-dark" style="font-size: 0.9rem;">My Academic Records</div>
                                <span class="text-muted d-block" style="font-size: 0.75rem; margin-top: 2px;">Manage and review current classes</span>
                            </div>
                        </a>

                        <a href="transport" class="d-flex align-items-center p-3 text-decoration-none bg-light bg-opacity-50 interactive-action-card" style="color: inherit; border-radius: 12px;">
                            <div class="d-flex align-items-center justify-content-center me-3" style="width: 44px; height: 44px; background-color: #ECFDF5; color: #10B981; min-width:44px; border-radius: 10px;"><i class="bi bi-map-fill fs-5"></i></div>
                            <div>
                                <div class="fw-bold text-dark" style="font-size: 0.9rem;">Transit Tracker</div>
                                <span class="text-muted d-block" style="font-size: 0.75rem; margin-top: 2px;">Check vehicle deployment updates</span>
                            </div>
                        </a>

                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .stats-card-vertical {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .stats-card-vertical:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.05) !important;
        }

    .shadow-inner {
        box-shadow: inset 0 2px 4px rgba(0,0,0,0.02);
    }
</style>