@page "/"
@using CampusServicePortal.Data
@inject UserSession Session

<PageTitle>Portal Core Dashboard</PageTitle>

<div class="container-fluid min-vh-100 p-0 d-flex flex-column flex-md-row" style="background-color: #F8FAFC; font-family: 'Inter', system-ui, -apple-system, sans-serif;">
    
    <div class="col-12 col-md-3 col-xl-2 bg-dark text-white d-flex flex-column justify-content-between border-end" style="background-color: #0A192F !important; min-height: 100vh; border-color: rgba(255,255,255,0.05) !important; z-index: 99;">
        <NavMenu />
    </div>

    <div class="col-12 col-md-9 col-xl-10 p-4 p-md-5 d-flex flex-column gap-4 overflow-auto">
        
        <div class="row g-0">
            <div class="col-12">
                <div class="p-4 p-md-5 text-white d-flex justify-content-between align-items-center flex-wrap gap-4 shadow-sm" style="background: linear-gradient(135deg, #1E3A8A 0%, #0F172A 100%); border-radius: 16px; border: 1px solid rgba(255,255,255,0.05);">
                    <div>
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <span class="spinner-grow spinner-grow-sm text-info" style="animation-duration: 1.5s; width: 8px; height: 8px;"></span>
                            <span class="text-info font-monospace text-uppercase small tracking-wider fw-bold" style="font-size: 0.75rem; letter-spacing: 1px;">Secure Network Node</span>
                        </div>
                        <h1 class="fw-bold display-6 m-0 text-white tracking-tight">
                            @(UserSession.CurrentUser?.Role?.RoleName == "Admin" ? "Administrative Control Panel" : "Student Command Hub")
                        </h1>
                        <p class="text-white-50 m-0 mt-2" style="max-width: 600px; font-size: 0.95rem; line-height: 1.5;">
                            Access your central core campus microservices, check updated real-time logs, and monitor your university profiles securely.
                        </p>
                    </div>
                    <div>
                        <span class="badge bg-white bg-opacity-10 border border-white border-opacity-25 px-4 py-3 rounded-pill fs-6 fw-semibold text-white shadow-sm">
                            <i class="bi bi-person-circle text-info me-2"></i> @(UserSession.CurrentUser?.FullName ?? "Guest Profile")
                        </span>
                    </div>
                </div>
            </div>
        </div>

        @if (UserSession.CurrentUser?.Role?.RoleName == "Admin" || UserSession.CurrentUser?.RoleId == 1)
        {
            <div class="row g-4">
                <div class="col-12 col-md-6 col-xl-3">
                    <div class="bg-white p-4 rounded-4 border d-flex align-items-center justify-content-between shadow-sm" style="border-radius: 14px; border-color: #E2E8F0 !important;">
                        <div>
                            <small class="text-muted text-uppercase font-monospace fw-bold" style="font-size: 0.7rem; letter-spacing: 0.5px;">System Base</small>
                            <h3 class="fw-bold m-0 mt-1 text-dark" style="font-size: 1.5rem;">150 Users</h3>
                        </div>
                        <div class="rounded-3 d-flex align-items-center justify-content-center" style="width: 50px; height: 50px; background-color: #EFF6FF; color: #2563EB; border-radius: 10px;"><i class="bi bi-people-fill fs-4"></i></div>
                    </div>
                </div>
                <div class="col-12 col-md-6 col-xl-3">
                    <div class="bg-white p-4 rounded-4 border d-flex align-items-center justify-content-between shadow-sm" style="border-radius: 14px; border-color: #E2E8F0 !important;">
                        <div>
                            <small class="text-muted text-uppercase font-monospace fw-bold" style="font-size: 0.7rem; letter-spacing: 0.5px;">Active Services</small>
                            <h3 class="fw-bold m-0 mt-1 text-dark" style="font-size: 1.5rem;">12 Nodes</h3>
                        </div>
                        <div class="rounded-3 d-flex align-items-center justify-content-center" style="width: 50px; height: 50px; background-color: #ECFDF5; color: #10B981; border-radius: 10px;"><i class="bi bi-cpu fs-4"></i></div>
                    </div>
                </div>
                <div class="col-12 col-md-6 col-xl-3">
                    <div class="bg-white p-4 rounded-4 border d-flex align-items-center justify-content-between shadow-sm" style="border-radius: 14px; border-color: #E2E8F0 !important;">
                        <div>
                            <small class="text-muted text-uppercase font-monospace fw-bold" style="font-size: 0.7rem; letter-spacing: 0.5px;">Pending Tickets</small>
                            <h3 class="fw-bold m-0 mt-1 text-danger" style="font-size: 1.5rem;">5 Alerts</h3>
                        </div>
                        <div class="rounded-3 d-flex align-items-center justify-content-center" style="width: 50px; height: 50px; background-color: #FEF2F2; color: #EF4444; border-radius: 10px;"><i class="bi bi-envelope-exclamation-fill fs-4"></i></div>
                    </div>
                </div>
                <div class="col-12 col-md-6 col-xl-3">
                    <div class="bg-white p-4 rounded-4 border d-flex align-items-center justify-content-between shadow-sm" style="border-radius: 14px; border-color: #E2E8F0 !important;">
                        <div>
                            <small class="text-muted text-uppercase font-monospace fw-bold" style="font-size: 0.7rem; letter-spacing: 0.5px;">Database Core</small>
                            <h3 class="fw-bold m-0 mt-1 text-success" style="font-size: 1.5rem;">Online</h3>
                        </div>
                        <div class="rounded-3 d-flex align-items-center justify-content-center" style="width: 50px; height: 50px; background-color: #F0FDF4; color: #16A34A; border-radius: 10px;"><i class="bi bi-shield-check-fill fs-4"></i></div>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="row g-4 flex-grow-1">
                <div class="col-12 col-lg-8">
                    <div class="card bg-white border shadow-sm h-100 overflow-hidden" style="border-radius: 16px; border-color: #E2E8F0 !important;">
                        <div class="card-header bg-white px-4 py-3 border-bottom d-flex align-items-center gap-2" style="border-color: #F1F5F9 !important;">
                            <i class="bi bi-bell-fill text-primary fs-5"></i>
                            <h5 class="m-0 fw-bold text-dark" style="font-size: 1rem;">Institutional Information Bulletin</h5>
                        </div>
                        <div class="card-body p-4 d-flex flex-column gap-3">
                            
                            <div class="p-3 border-start border-4 border-danger rounded shadow-sm" style="background-color: #FFF5F5; border-radius: 8px;">
                                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-2">
                                    <h6 class="fw-bold text-dark m-0" style="font-size: 0.95rem;">Fall 2024 Exam Timetables Published</h6>
                                    <span class="badge bg-danger bg-opacity-10 text-danger px-2.5 py-1.5 rounded-pill font-monospace small fw-bold" style="font-size: 0.7rem;">CRITICAL</span>
                                </div>
                                <p class="text-secondary small m-0" style="line-height: 1.5; font-size: 0.85rem;">The complete unified examination matrix has been confirmed. Review targets, venue coordinates, and student seat codes immediately.</p>
                            </div>

                            <div class="p-3 border-start border-4 border-primary rounded shadow-sm" style="background-color: #F0F9FF; border-radius: 8px;">
                                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-2">
                                    <h6 class="fw-bold text-dark m-0" style="font-size: 0.95rem;">Transit Logistics Corridor Extensions</h6>
                                    <span class="badge bg-primary bg-opacity-10 text-primary px-2.5 py-1.5 rounded-pill font-monospace small fw-bold" style="font-size: 0.7rem;">LOGISTICS</span>
                                </div>
                                <p class="text-secondary small m-0" style="line-height: 1.5; font-size: 0.85rem;">Shuttle vehicle deployment capacity counts have been doubled along major suburban lanes for rush hour commuters.</p>
                            </div>

                        </div>
                    </div>
                </div>

                <div class="col-12 col-lg-4">
                    <div class="card bg-white border shadow-sm h-100 overflow-hidden" style="border-radius: 16px; border-color: #E2E8F0 !important;">
                        <div class="card-header bg-white px-4 py-3 border-bottom" style="border-color: #F1F5F9 !important;">
                            <h5 class="m-0 fw-bold text-dark" style="font-size: 1rem;"><i class="bi bi-lightning-charge-fill text-warning me-1"></i>Quick System Actions</h5>
                        </div>
                        <div class="card-body p-4 d-flex flex-column gap-3">
                            
                            <a href="courses" class="d-flex align-items-center p-3 border rounded-3 text-decoration-none shadow-sm bg-light bg-opacity-50" style="color: inherit; border-radius: 12px; border-color: #E2E8F0 !important; transition: all 0.2s ease-in-out;" onmouseover="this.style.borderColor='#0284c7'; this.style.backgroundColor='#f0f9ff'; this.style.transform='translateY(-2px)';" onmouseout="this.style.borderColor='#e5e7eb'; this.style.backgroundColor='rgba(248,249,250,0.5)'; this.style.transform='none';">
                                <div class="rounded-3 d-flex align-items-center justify-content-center me-3" style="width: 44px; height: 44px; background-color: #EFF6FF; color: #2563EB; min-width: 44px; border-radius: 8px;"><i class="bi bi-collection-play-fill fs-5"></i></div>
                                <div>
                                    <div class="fw-bold text-dark" style="font-size: 0.88rem;">My Academic Records</div>
                                    <span class="text-muted d-block mt-0.5" style="font-size: 0.75rem;">Manage and review current classes</span>
                                </div>
                            </a>

                            <a href="transport" class="d-flex align-items-center p-3 border rounded-3 text-decoration-none shadow-sm bg-light bg-opacity-50" style="color: inherit; border-radius: 12px; border-color: #E2E8F0 !important; transition: all 0.2s ease-in-out;" onmouseover="this.style.borderColor='#10b981'; this.style.backgroundColor='#ecfdf5'; this.style.transform='translateY(-2px)';" onmouseout="this.style.borderColor='#e5e7eb'; this.style.backgroundColor='rgba(248,249,250,0.5)'; this.style.transform='none';">
                                <div class="rounded-3 d-flex align-items-center justify-content-center me-3" style="width: 44px; height: 44px; background-color: #ECFDF5; color: #10B981; min-width: 44px; border-radius: 8px;"><i class="bi bi-map-fill fs-5"></i></div>
                                <div>
                                    <div class="fw-bold text-dark" style="font-size: 0.88rem;">Transit Tracker</div>
                                    <span class="text-muted d-block mt-0.5" style="font-size: 0.75rem;">Check vehicle deployment updates</span>
                                </div>
                            </a>

                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>