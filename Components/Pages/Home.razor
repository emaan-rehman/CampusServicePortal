@page "/"
@using CampusServicePortal.Data
@inject UserSession Session

<PageTitle>Portal Core Dashboard</PageTitle>

<div class="p-4 p-md-5">
    
    <div class="row mb-4 g-0">
        <div class="col-12">
            <div class="p-5 text-white d-flex justify-content-between align-items-center flex-wrap gap-4 shadow-sm" style="background: linear-gradient(135deg, #1E3A8A 0%, #0F172A 100%); border-radius: 16px;">
                <div>
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <span class="spinner-grow spinner-grow-sm text-info" style="animation-duration: 1.5s;"></span>
                        <span class="text-info font-monospace text-uppercase small tracking-wider fw-bold" style="font-size: 0.75rem;">Secure Network Node</span>
                    </div>
                    <h1 class="fw-black display-6 m-0 text-white">
                        @(UserSession.CurrentUser?.Role?.RoleName == "Admin" ? "Administrative Control Panel" : "Student Command Hub")
                    </h1>
                    <p class="text-white-50 m-0 mt-2" style="max-width: 600px;">Access your central core campus microservices, check updated real-time logs, and monitor your university profiles securely.</p>
                </div>
                <div>
                    <span class="badge bg-white bg-opacity-10 border border-white border-opacity-25 px-4 py-3 rounded-pill fs-6 fw-semibold text-white">
                        <i class="bi bi-person-circle text-info me-2"></i> @(UserSession.CurrentUser?.FullName ?? "Guest Profile")
                    </span>
                </div>
            </div>
        </div>
    </div>

    @if (UserSession.CurrentUser?.Role?.RoleName == "Admin" || UserSession.CurrentUser?.RoleId == 1)
    {
        <div class="row g-4">
            <div class="col-12 col-md-6 col-xl-3">
                <div class="bg-white p-4 rounded-4 border d-flex align-items-center justify-content-between shadow-sm">
                    <div>
                        <small class="text-muted text-uppercase font-monospace fw-bold" style="font-size: 0.7rem;">System Base</small>
                        <h3 class="fw-bold m-0 mt-1 text-dark">150 Users</h3>
                    </div>
                    <div class="rounded-3 d-flex align-items-center justify-content-center" style="width: 50px; height: 50px; background-color: #eff6ff; color: #2563eb;"><i class="bi bi-people-fill fs-4"></i></div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-xl-3">
                <div class="bg-white p-4 rounded-4 border d-flex align-items-center justify-content-between shadow-sm">
                    <div>
                        <small class="text-muted text-uppercase font-monospace fw-bold" style="font-size: 0.7rem;">Active Services</small>
                        <h3 class="fw-bold m-0 mt-1 text-dark">12 Nodes</h3>
                    </div>
                    <div class="rounded-3 d-flex align-items-center justify-content-center" style="width: 50px; height: 50px; background-color: #ecfdf5; color: #10b981;"><i class="bi bi-cpu fs-4"></i></div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-xl-3">
                <div class="bg-white p-4 rounded-4 border d-flex align-items-center justify-content-between shadow-sm">
                    <div>
                        <small class="text-muted text-uppercase font-monospace fw-bold" style="font-size: 0.7rem;">Pending Tickets</small>
                        <h3 class="fw-bold m-0 mt-1 text-danger">5 Alerts</h3>
                    </div>
                    <div class="rounded-3 d-flex align-items-center justify-content-center" style="width: 50px; height: 50px; background-color: #fef2f2; color: #ef4444;"><i class="bi bi-envelope-exclamation-fill fs-4"></i></div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-xl-3">
                <div class="bg-white p-4 rounded-4 border d-flex align-items-center justify-content-between shadow-sm">
                    <div>
                        <small class="text-muted text-uppercase font-monospace fw-bold" style="font-size: 0.7rem;">Database Core</small>
                        <h3 class="fw-bold m-0 mt-1 text-success">Online</h3>
                    </div>
                    <div class="rounded-3 d-flex align-items-center justify-content-center" style="width: 50px; height: 50px; background-color: #f0fdf4; color: #16a34a;"><i class="bi bi-shield-check-fill fs-4"></i></div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-12 col-lg-8">
                <div class="card bg-white border shadow-sm rounded-4 h-100 overflow-hidden">
                    <div class="card-header bg-white px-4 py-3 border-bottom d-flex align-items-center gap-2">
                        <i class="bi bi-bell-fill text-primary fs-5"></i>
                        <h5 class="m-0 fw-bold text-dark">Verified Institutional Information Bulletin</h5>
                    </div>
                    <div class="card-body p-4 d-flex flex-column gap-3">
                        
                        <div class="p-3 border-start border-4 border-danger rounded shadow-2xs" style="background-color: #fff5f5;">
                            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-1">
                                <h6 class="fw-bold text-dark m-0">Fall 2024 Exam Timetables Published</h6>
                                <span class="badge bg-danger bg-opacity-10 text-danger px-2.5 py-1 rounded-pill font-monospace small">CRITICAL</span>
                            </div>
                            <p class="text-muted small m-0">The complete unified examination matrix has been confirmed. Review targets, venue coordinates, and student seat codes immediately.</p>
                        </div>

                        <div class="p-3 border-start border-4 border-primary rounded shadow-2xs" style="background-color: #f0f9ff;">
                            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-1">
                                <h6 class="fw-bold text-dark m-0">Transit Logistics Corridor Extensions</h6>
                                <span class="badge bg-primary bg-opacity-10 text-primary px-2.5 py-1 rounded-pill font-monospace small">LOGISTICS</span>
                            </div>
                            <p class="text-muted small m-0">Shuttle vehicle deployment capacity counts have been doubled along major suburban lanes for rush hour commuters.</p>
                        </div>

                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-4">
                <div class="card bg-white border shadow-sm rounded-4 h-100 overflow-hidden">
                    <div class="card-header bg-white px-4 py-3 border-bottom">
                        <h5 class="m-0 fw-bold text-dark"><i class="bi bi-lightning-charge-fill text-warning me-1"></i>Quick System Actions</h5>
                    </div>
                    <div class="card-body p-4 d-flex flex-column gap-3">
                        
                        <a href="courses" class="d-flex align-items-center p-3 border rounded-3 text-container text-decoration-none bg-light bg-opacity-50 transition-all" style="color: inherit;" onmouseover="this.style.borderColor='#0284c7'; this.style.backgroundColor='#f0f9ff';" onmouseout="this.style.borderColor='#e5e7eb'; this.style.backgroundColor='rgba(248,249,250,0.5)';">
                            <div class="rounded-3 d-flex align-items-center justify-content-center me-3" style="width: 46px; height: 46px; background-color: #eff6ff; color: #2563eb; min-width:46px;"><i class="bi bi-collection-play-fill fs-4"></i></div>
                            <div>
                                <div class="fw-bold text-dark small">My Academic Records</div>
                                <span class="text-muted" style="font-size: 0.75rem;">Manage and review current classes</span>
                            </div>
                        </a>

                        <a href="transport" class="d-flex align-items-center p-3 border rounded-3 text-container text-decoration-none bg-light bg-opacity-50 transition-all" style="color: inherit;" onmouseover="this.style.borderColor='#10b981'; this.style.backgroundColor='#ecfdf5';" onmouseout="this.style.borderColor='#e5e7eb'; this.style.backgroundColor='rgba(248,249,250,0.5)';">
                            <div class="rounded-3 d-flex align-items-center justify-content-center me-3" style="width: 46px; height: 46px; background-color: #ecfdf5; color: #10b981; min-width:46px;"><i class="bi bi-map-fill fs-4"></i></div>
                            <div>
                                <div class="fw-bold text-dark small">Transit Tracker</div>
                                <span class="text-muted" style="font-size: 0.75rem;">Check vehicle deployment updates</span>
                            </div>
                        </a>

                    </div>
                </div>
            </div>
        </div>
    }
</div>