@page "/"
@using CampusServicePortal.Data
@inject UserSession Session

<PageTitle>Portal Core Dashboard</PageTitle>

<div class="container-fluid p-0">
    <div class="row mb-4">
        <div class="col-12">
            <div class="hero-glass-card text-white d-flex justify-content-between align-items-center flex-wrap gap-4">
                <div>
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <span class="spinner-grow spinner-grow-sm text-info" style="animation-duration: 1.5s;"></span>
                        <span class="text-info font-monospace text-uppercase small fw-bold tracking-wider" style="font-size: 0.75rem;">Secure Network Node</span>
                    </div>
                    <h1 class="fw-bold display-6 m-0 text-white">
                        @(UserSession.CurrentUser?.Role?.RoleName == "Admin" ? "Administrative Control Panel" : "Student Command Hub")
                    </h1>
                    <p class="text-white-50 m-0 mt-2" style="max-width: 600px; font-size: 0.95rem; line-height: 1.5;">
                        Access your central core campus microservices, check updated real-time logs, and monitor your university profiles securely.
                    </p>
                </div>
                <div>
                    <span class="badge bg-white bg-opacity-10 border border-white border-opacity-25 px-4 py-3 rounded-pill fs-6 fw-semibold text-white shadow-sm">
                        <i class="bi bi-person-circle text-info me-2"></i> @(UserSession.CurrentUser?.FullName ?? "Guest Profile")
                    </span>
                </div>
            </div>
        </div>
    </div>

    @if (UserSession.CurrentUser?.Role?.RoleName == "Admin" || UserSession.CurrentUser?.RoleId == 1)
    {
        <div class="row g-4">
            <div class="col-12 col-md-6 col-xl-3">
                <div class="metric-pill-card">
                    <div>
                        <small class="text-muted text-uppercase font-monospace fw-bold" style="font-size: 0.7rem; letter-spacing: 0.5px;">System Base</small>
                        <h3 class="fw-bold m-0 mt-1 text-dark">150 Users</h3>
                    </div>
                    <div class="icon-container" style="background-color: #eff6ff; color: #2563eb;">
                        <i class="bi bi-people-fill fs-4"></i>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-xl-3">
                <div class="metric-pill-card">
                    <div>
                        <small class="text-muted text-uppercase font-monospace fw-bold" style="font-size: 0.7rem; letter-spacing: 0.5px;">Active Services</small>
                        <h3 class="fw-bold m-0 mt-1 text-dark">12 Nodes</h3>
                    </div>
                    <div class="icon-container" style="background-color: #ecfdf5; color: #10b981;">
                        <i class="bi bi-cpu fs-4"></i>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-xl-3">
                <div class="metric-pill-card">
                    <div>
                        <small class="text-muted text-uppercase font-monospace fw-bold" style="font-size: 0.7rem; letter-spacing: 0.5px;">Pending Tickets</small>
                        <h3 class="fw-bold m-0 mt-1 text-danger">5 Alerts</h3>
                    </div>
                    <div class="icon-container" style="background-color: #fef2f2; color: #ef4444;">
                        <i class="bi bi-envelope-exclamation-fill fs-4"></i>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-xl-3">
                <div class="metric-pill-card">
                    <div>
                        <small class="text-muted text-uppercase font-monospace fw-bold" style="font-size: 0.7rem; letter-spacing: 0.5px;">Database Core</small>
                        <h3 class="fw-bold m-0 mt-1 text-success">Online</h3>
                    </div>
                    <div class="icon-container" style="background-color: #f0fdf4; color: #16a34a;">
                        <i class="bi bi-shield-check-fill fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-12 col-lg-8">
                <div class="card board-card h-100">
                    <div class="card-header board-header d-flex align-items-center gap-2">
                        <i class="bi bi-bell-fill text-primary fs-5"></i>
                        <h5 class="m-0 fw-bold text-dark">Verified Institutional Information Bulletin</h5>
                    </div>
                    <div class="card-body p-4 d-flex flex-column gap-3">
                        
                        <div class="p-3 border-start border-4 border-danger rounded shadow-sm" style="background-color: #fff5f5;">
                            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-2">
                                <h6 class="fw-bold text-dark m-0">Fall 2024 Exam Timetables Published</h6>
                                <span class="bulletin-badge-critical">CRITICAL</span>
                            </div>
                            <p class="text-secondary m-0" style="font-size: 0.875rem; line-height: 1.4;">
                                The complete unified examination matrix has been confirmed. Review targets, venue coordinates, and student seat codes immediately.
                            </p>
                        </div>

                        <div class="p-3 border-start border-4 border-primary rounded shadow-sm" style="background-color: #f0f9ff;">
                            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-2">
                                <h6 class="fw-bold text-dark m-0">Transit Logistics Corridor Extensions</h6>
                                <span class="bulletin-badge-info">LOGISTICS</span>
                            </div>
                            <p class="text-secondary m-0" style="font-size: 0.875rem; line-height: 1.4;">
                                Shuttle vehicle deployment capacity counts have been doubled along major suburban lanes for rush hour commuters.
                            </p>
                        </div>

                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-4">
                <div class="card board-card h-100">
                    <div class="card-header board-header">
                        <h5 class="m-0 fw-bold text-dark">
                            <i class="bi bi-lightning-charge-fill text-warning me-1"></i>Quick System Actions
                        </h5>
                    </div>
                    <div class="card-body p-4 d-flex flex-column gap-3">
                        
                        <a href="courses" class="action-shortcut">
                            <div class="icon-container me-3" style="width: 44px; height: 44px; background-color: #eff6ff; color: #2563eb; min-width:44px;">
                                <i class="bi bi-collection-play-fill fs-5"></i>
                            </div>
                            <div>
                                <div class="fw-bold text-dark" style="font-size: 0.9rem;">My Academic Records</div>
                                <span class="text-muted d-block" style="font-size: 0.78rem;">Manage and review current classes</span>
                            </div>
                        </a>

                        <a href="transport" class="action-shortcut">
                            <div class="icon-container me-3" style="width: 44px; height: 44px; background-color: #ecfdf5; color: #10b981; min-width:44px;">
                                <i class="bi bi-map-fill fs-5"></i>
                            </div>
                            <div>
                                <div class="fw-bold text-dark" style="font-size: 0.9rem;">Transit Tracker</div>
                                <span class="text-muted d-block" style="font-size: 0.78rem;">Check vehicle deployment updates</span>
                            </div>
                        </a>

                    </div>
                </div>
            </div>
        </div>
    }
</div>