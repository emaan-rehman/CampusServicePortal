@page "/library"
@rendermode InteractiveServer
@inject ICampusRepository Repo

<div class="container mt-4">
    <h3>Library Resource Management</h3>
    <div class="row">
        <div class="col-md-12">
            <table class="table">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Author</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Database Systems</td>
                        <td>C.J. Date</td>
                        <td>Available</td>
                        <td><button class="btn btn-sm btn-primary">Reserve</button></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>