@page "/Library"
@using CampusServicePortal.Repositories
@using CampusServicePortal.Data
@rendermode InteractiveServer
@inject ICampusRepository Repo
@code {
    private List<Book> books = new();

    protected override async Task OnInitializedAsync()
    {
        books = await Repo.GetBooksAsync();
    }
}

<tbody>
    @foreach (var book in books)
    {
        <tr>
            <td>@book.Title</td>
            <td>Author Name</td>
            <td>@(book.IsAvailable ? "Available" : "Checked Out")</td>
            <td>
                <button class="btn btn-sm btn-primary" disabled="@(!book.IsAvailable)">
                    Reserve
                </button>
            </td>
        </tr>
    }
</tbody>