@page "/faculty"
@using CampusServicePortal.Data
@using CampusServicePortal.Repositories
@inject ICampusRepository Repo

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark"><i class="bi bi-person-badge text-primary"></i> Faculty Management</h2>
        <button class="btn btn-primary" @onclick="() => showForm = !showForm">
            @(showForm ? "Close Form" : "Add New Faculty")
        </button>
    </div>

    @if (showForm)
    {
        <div class="card card-body mb-4 shadow-sm border-primary">
            <h5 class="fw-bold mb-3">Register New Faculty Member</h5>
            <div class="row g-3">
                <div class="col-md-4">
                    <input type="text" class="form-control" placeholder="Full Name" @bind="newFaculty.Name" />
                </div>
                <div class="col-md-3">
                    <input type="text" class="form-control" placeholder="Department" @bind="newFaculty.Department" />
                </div>
                <div class="col-md-3">
                    <input type="email" class="form-control" placeholder="Email Address" @bind="newFaculty.Email" />
                </div>
                <div class="col-md-2">
                    <button class="btn btn-success w-100" @onclick="SaveFaculty">Save</button>
                </div>
            </div>
        </div>
    }

    @if (facultyList == null)
    {
        <p>Loading faculty data...</p>
    }
    else
    {
        <div class="table-responsive shadow-sm rounded">
            <table class="table table-hover bg-white mb-0">
                <thead class="table-primary">
                    <tr>
                        <th class="ps-3">Name</th>
                        <th>Department</th>
                        <th>Email</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var f in facultyList)
                    {
                        <tr>
                            <td class="ps-3 fw-bold">@f.Name</td>
                            <td><span class="badge bg-info text-dark">@f.Department</span></td>
                            <td>@f.Email</td>
                            <td>
                                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<Faculty>? facultyList;
    private bool showForm = false;
    private Faculty newFaculty = new Faculty();

    protected override async Task OnInitializedAsync()
    {
        await LoadFaculty();
    }

    private async Task LoadFaculty() => facultyList = await Repo.GetAllFacultyAsync();

    private async Task SaveFaculty()
    {
        if (!string.IsNullOrWhiteSpace(newFaculty.Name))
        {
            await Repo.AddFacultyAsync(newFaculty);
            newFaculty = new Faculty();
            showForm = false;
            await LoadFaculty();
        }
    }
}