@using CampusServicePortal.Data

<div class="sidebar-wrapper" style="background-color: #0A192F; height: 100vh; width: 100%; display: flex; flex-direction: column; overflow: hidden; box-sizing: border-box;">
    
    <div style="display: flex; align-items: center; padding: 0 1.5rem; height: 70px; min-height: 70px; background-color: #020C1B; border-bottom: 1px solid rgba(255,255,255,0.06); flex-shrink: 0;">
        <div style="display: flex; align-items: center; justify-content: center; background-color: rgba(0, 180, 216, 0.1); rounded: 6px; width: 38px; height: 38px; min-width: 38px; border: 1px solid rgba(100, 255, 218, 0.25); border-radius: 8px; margin-right: 12px;">
            <i class="bi bi-mortarboard-fill" style="color: #00b4d8; font-size: 1.25rem;"></i>
        </div>
        <span style="color: #FFFFFF; fw-bold: 700; font-weight: 700; font-size: 1.15rem; letter-spacing: 0.75px; font-family: 'Inter', sans-serif;">Smart Campus</span>
    </div>

    <div style="flex-grow: 1; overflow-y: auto; padding: 1.5rem 1rem;">
        <nav style="display: flex; flex-direction: column; width: 100%; gap: 6px;">
            
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All" style="display: flex !important; align-items: center !important; padding: 12px 16px !important; border-radius: 10px !important; text-decoration: none !important; background-color: rgba(255,255,255,0.03) !important; border: 1px solid rgba(255,255,255,0.05) !important; transition: all 0.2s ease !important;">
                <div style="display: flex; align-items: center; justify-content: center; width: 34px; height: 34px; min-width: 34px; border-radius: 8px; background-color: rgba(255, 255, 255, 0.03); color: #38BDF8; margin-right: 12px; font-size: 1.1rem; border: 1px solid rgba(255, 255, 255, 0.05);">
                    <i class="bi bi-columns-gap"></i>
                </div>
                <span style="color: #38BDF8 !important; font-weight: 600 !important; font-size: 0.925rem !important; text-decoration: none !important;">Dashboard Panel</span>
            </NavLink>

            @if (UserSession.CurrentUser != null)
            {
                var user = UserSession.CurrentUser;
                var role = user.Role?.RoleName;

                @if (role == "Student" || user.RoleId == 2)
                {
                    <div style="display: flex; align-items: center; font-weight: 700; font-size: 0.725rem; letter-spacing: 1.5px; color: #64FFDA; text-transform: uppercase; padding: 1.5rem 0.5rem 0.5rem 0.5rem;">
                        <span style="width: 6px; height: 6px; border-radius: 50%; background-color: #64FFDA; margin-right: 8px; display: inline-block; box-shadow: 0 0 6px #64FFDA;"></span> Academic Core
                    </div>
                    
                    <NavLink class="nav-link" href="courses" style="display: flex !important; align-items: center !important; padding: 10px 16px !important; border-radius: 10px !important; text-decoration: none !important; transition: all 0.2s ease !important;">
                        <div style="display: flex; align-items: center; justify-content: center; width: 34px; height: 34px; min-width: 34px; border-radius: 8px; background-color: rgba(255,255,255,0.02); color: #94A3B8; margin-right: 12px; font-size: 1.05rem;"><i class="bi bi-book"></i></div>
                        <span style="color: #CBD5E1 !important; font-size: 0.9rem !important; text-decoration: none !important;">My Courses</span>
                    </NavLink>
                    
                    <NavLink class="nav-link" href="transport" style="display: flex !important; align-items: center !important; padding: 10px 16px !important; border-radius: 10px !important; text-decoration: none !important; transition: all 0.2s ease !important;">
                        <div style="display: flex; align-items: center; justify-content: center; width: 34px; height: 34px; min-width: 34px; border-radius: 8px; background-color: rgba(255,255,255,0.02); color: #94A3B8; margin-right: 12px; font-size: 1.05rem;"><i class="bi bi-bus-front"></i></div>
                        <span style="color: #CBD5E1 !important; font-size: 0.9rem !important; text-decoration: none !important;">Transport Route</span>
                    </NavLink>
                    
                    <NavLink class="nav-link" href="Library" style="display: flex !important; align-items: center !important; padding: 10px 16px !important; border-radius: 10px !important; text-decoration: none !important; transition: all 0.2s ease !important;">
                        <div style="display: flex; align-items: center; justify-content: center; width: 34px; height: 34px; min-width: 34px; border-radius: 8px; background-color: rgba(255,255,255,0.02); color: #94A3B8; margin-right: 12px; font-size: 1.05rem;"><i class="bi bi-journal-bookmark"></i></div>
                        <span style="color: #CBD5E1 !important; font-size: 0.9rem !important; text-decoration: none !important;">Digital Library</span>
                    </NavLink>
                    
                    <NavLink class="nav-link" href="fees" style="display: flex !important; align-items: center !important; padding: 10px 16px !important; border-radius: 10px !important; text-decoration: none !important; transition: all 0.2s ease !important;">
                        <div style="display: flex; align-items: center; justify-content: center; width: 34px; height: 34px; min-width: 34px; border-radius: 8px; background-color: rgba(255,255,255,0.02); color: #94A3B8; margin-right: 12px; font-size: 1.05rem;"><i class="bi bi-credit-card"></i></div>
                        <span style="color: #CBD5E1 !important; font-size: 0.9rem !important; text-decoration: none !important;">Tuition Fees</span>
                    </NavLink>
                    
                    <NavLink class="nav-link" href="Complaints" style="display: flex !important; align-items: center !important; padding: 10px 16px !important; border-radius: 10px !important; text-decoration: none !important; transition: all 0.2s ease !important;">
                        <div style="display: flex; align-items: center; justify-content: center; width: 34px; height: 34px; min-width: 34px; border-radius: 8px; background-color: rgba(255,255,255,0.02); color: #94A3B8; margin-right: 12px; font-size: 1.05rem;"><i class="bi bi-chat-left-dots"></i></div>
                        <span style="color: #CBD5E1 !important; font-size: 0.9rem !important; text-decoration: none !important;">Helpdesk Tickets</span>
                    </NavLink>
                }

                @if (role == "Admin" || user.RoleId == 1)
                {
                    <div style="display: flex; align-items: center; font-weight: 700; font-size: 0.725rem; letter-spacing: 1.5px; color: #F59E0B; text-transform: uppercase; padding: 1.75rem 0.5rem 0.5rem 0.5rem;">
                        <span style="width: 6px; height: 6px; border-radius: 50%; background-color: #F59E0B; margin-right: 8px; display: inline-block; box-shadow: 0 0 6px #F59E0B;"></span> Administration Control
                    </div>
                    
                    <NavLink class="nav-link" href="RoleManagement" style="display: flex !important; align-items: center !important; padding: 11px 16px !important; border-radius: 10px !important; text-decoration: none !important; transition: all 0.2s ease !important; margin-bottom: 4px;">
                        <div style="display: flex; align-items: center; justify-content: center; width: 34px; height: 34px; min-width: 34px; border-radius: 8px; background-color: rgba(255,255,255,0.02); color: #CBD5E1; margin-right: 12px; font-size: 1.05rem;"><i class="bi bi-shield-lock"></i></div>
                        <span style="color: #E2E8F0 !important; font-size: 0.925rem !important; font-weight: 500 !important; text-decoration: none !important;">Access Control</span>
                    </NavLink>
                    
                    <NavLink class="nav-link" href="faculty" style="display: flex !important; align-items: center !important; padding: 11px 16px !important; border-radius: 10px !important; text-decoration: none !important; transition: all 0.2s ease !important;">
                        <div style="display: flex; align-items: center; justify-content: center; width: 34px; height: 34px; min-width: 34px; border-radius: 8px; background-color: rgba(255,255,255,0.02); color: #CBD5E1; margin-right: 12px; font-size: 1.05rem;"><i class="bi bi-person-badge"></i></div>
                        <span style="color: #E2E8F0 !important; font-size: 0.925rem !important; font-weight: 500 !important; text-decoration: none !important;">Faculty Registry</span>
                    </NavLink>
                }
            }
        </nav>
    </div>

    @if (UserSession.CurrentUser != null)
    {
        <div style="padding: 1rem; padding-bottom: 1.5rem; flex-shrink: 0; width: 100%; box-sizing: border-box;">
            <div style="background-color: #112240; padding: 12px 16px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.06); display: flex; align-items: center; width: 100%; box-sizing: border-box;">
                <div style="background-color: #00b4d8; color: #0A192F; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; margin-right: 12px; width: 40px; height: 40px; min-width: 40px; font-size: 0.95rem; border: 2px solid rgba(100, 255, 218, 0.25);">
                    @UserSession.CurrentUser.FullName.Substring(0, 1).ToUpper()
                </div>
                <div style="overflow: hidden; display: flex; flex-direction: column;">
                    <div style="color: #FFFFFF; font-weight: 600; font-size: 0.875rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@UserSession.CurrentUser.FullName</div>
                    <small style="color: #94A3B8; font-family: monospace; font-size: 0.725rem; margin-top: 2px;">ID: #@UserSession.CurrentUser.UserId</small>
                </div>
            </div>
        </div>
    }
</div>