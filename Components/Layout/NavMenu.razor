@using CampusServicePortal.Data

<div class="w-100 d-flex flex-column h-100" style="background-color: var(--navy-dark);">
    <div class="brand-header">
        <i class="bi bi-mortarboard-fill text-info fs-3 me-2"></i>
        <span class="text-white fw-bold fs-5 tracking-wider" style="letter-spacing: 0.5px;">Smart Campus</span>
    </div>

    <div class="nav-scroller">
        <nav class="d-flex flex-column gap-1">
            
            <NavLink class="nav-item-link" href="" Match="NavLinkMatch.All">
                <i class="bi bi-columns-gap"></i>
                <span>Dashboard Panel</span>
            </NavLink>

            @if (UserSession.CurrentUser != null)
            {
                var user = UserSession.CurrentUser;
                var role = user.Role?.RoleName;

                @if (role == "Student" || user.RoleId == 2)
                {
                    <div class="section-divider-title">Academic Core</div>
                    
                    <NavLink class="nav-item-link" href="courses">
                        <i class="bi bi-book"></i><span>My Courses</span>
                    </NavLink>
                    
                    <NavLink class="nav-item-link" href="transport">
                        <i class="bi bi-bus-front"></i><span>Transport Route</span>
                    </NavLink>
                    
                    <NavLink class="nav-item-link" href="Library">
                        <i class="bi bi-journal-bookmark"></i><span>Digital Library</span>
                    </NavLink>
                    
                    <NavLink class="nav-item-link" href="fees">
                        <i class="bi bi-credit-card"></i><span>Tuition Fees</span>
                    </NavLink>
                    
                    <NavLink class="nav-item-link" href="Complaints">
                        <i class="bi bi-chat-left-dots"></i><span>Helpdesk Tickets</span>
                    </NavLink>
                }

                @if (role == "Admin" || user.RoleId == 1)
                {
                    <div class="section-divider-title" style="color: #F59E0B;">Administration</div>
                    
                    <NavLink class="nav-item-link" href="RoleManagement">
                        <i class="bi bi-shield-lock"></i><span>Access Control</span>
                    </NavLink>
                    
                    <NavLink class="nav-item-link" href="faculty">
                        <i class="bi bi-person-badge"></i><span>Faculty Registry</span>
                    </NavLink>
                }
            }
        </nav>
    </div>

    @if (UserSession.CurrentUser != null)
    {
        <div class="p-3 mt-auto">
            <div class="user-footer-card">
                <div class="d-flex align-items-center">
                    <div class="bg-info text-dark rounded-circle d-flex align-items-center justify-content-center fw-bold me-2 shadow-sm" style="width: 38px; height: 38px; min-width: 38px; font-size: 0.95rem;">
                        @UserSession.CurrentUser.FullName.Substring(0, 1).ToUpper()
                    </div>
                    <div class="overflow-hidden">
                        <div class="text-white text-truncate fw-bold" style="font-size: 0.85rem;">@UserSession.CurrentUser.FullName</div>
                        <small class="text-muted d-block font-monospace" style="font-size: 0.7rem; opacity: 0.7;">ID: #@UserSession.CurrentUser.UserId</small>
                    </div>
                </div>
            </div>
        </div>
    }
</div>