@using CampusServicePortal.Data

<div class="d-flex flex-column h-100 w-100">
    <div class="brand-header">
        <i class="bi bi-mortarboard-fill text-info fs-3 me-2"></i>
        <span class="text-white fw-bold tracking-wider fs-5">Smart Campus</span>
    </div>

    <div class="nav-scroller">
        <nav class="nav flex-column">
            <NavLink class="nav-item-link" href="" Match="NavLinkMatch.All">
                <i class="bi bi-columns-gap"></i> <span>Dashboard Center</span>
            </NavLink>

            @if (UserSession.CurrentUser != null)
            {
                var user = UserSession.CurrentUser;
                var role = user.Role?.RoleName;

                @if (role == "Student" || user.RoleId == 2)
                {
                    <div class="section-divider-title">Academic Services</div>
                    <NavLink class="nav-item-link" href="courses"><i class="bi bi-journal-text"></i> My Courses</NavLink>
                    <NavLink class="nav-item-link" href="transport"><i class="bi bi-bus-front"></i> Transport Track</NavLink>
                    <NavLink class="nav-item-link" href="Library"><i class="bi bi-book"></i> Digital Library</NavLink>
                    <NavLink class="nav-item-link" href="fees"><i class="bi bi-wallet2"></i> Tuition Fees</NavLink>
                    <NavLink class="nav-item-link" href="events"><i class="bi bi-calendar-event"></i> Campus Events</NavLink>
                    <NavLink class="nav-item-link" href="Complaints"><i class="bi bi-chat-left-dots"></i> Helpdesk Tickets</NavLink>
                }

                @if (role == "Admin" || user.RoleId == 1)
                {
                    <div class="section-divider-title text-warning">Administration</div>
                    <NavLink class="nav-item-link" href="RoleManagement"><i class="bi bi-shield-lock"></i> Access Control</NavLink>
                    <NavLink class="nav-item-link" href="faculty"><i class="bi bi-person-workspace"></i> Faculty Registry</NavLink>
                }

                <div class="section-divider-title">General Portals</div>
                <NavLink class="nav-item-link" href="exams"><i class="bi bi-file-earmark-spreadsheet"></i> Examinations</NavLink>
                <NavLink class="nav-item-link" href="hostel"><i class="bi bi-building"></i> Hostel Portals</NavLink>
                <NavLink class="nav-item-link" href="cafe"><i class="bi bi-cup-hot"></i> Café Lounge</NavLink>

                <div class="mt-4 pt-3 border-top border-secondary border-opacity-20">
                    <div class="user-footer-card">
                        <div class="d-flex align-items-center">
                            <div class="bg-info text-dark rounded-circle d-flex align-items-center justify-content-center fw-bold me-2" style="width: 36px; height: 36px; min-width: 36px;">
                                @user.FullName.Substring(0, 1).ToUpper()
                            </div>
                            <div class="text-truncate">
                                <div class="text-white small fw-bold text-truncate">@user.FullName</div>
                                <span class="text-muted font-monospace" style="font-size: 0.75rem;">ID: #@user.UserId</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </nav>
    </div>
</div>