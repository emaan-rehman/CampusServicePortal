@using CampusServicePortal.Data

<div class="top-row ps-4 navbar navbar-dark bg-dark border-bottom border-secondary">
    <div class="container-fluid">
        <a class="navbar-brand fw-bold text-white d-flex align-items-center" href="">
            <i class="bi bi-mortarboard-fill text-warning me-2 fs-4"></i>
            <span style="letter-spacing: 0.5px;">CampusPortal</span>
        </a>
    </div>
</div>

<div class="nav-scrollable bg-dark" style="min-height: calc(100vh - 56px);">
    <nav class="flex-column nav-pills p-3">
        
        @* DASHBOARD LINK *@
        <div class="nav-item mb-3">
            <NavLink class="nav-link text-white d-flex align-items-center rounded-3 px-3 py-2" href="" Match="NavLinkMatch.All">
                <i class="bi bi-speedometer2 text-info me-3 fs-5"></i>
                <span class="fw-medium">Dashboard</span>
            </NavLink>
        </div>

        @if (UserSession.CurrentUser != null)
        {
            var user = UserSession.CurrentUser;
            var role = user.Role?.RoleName;

            @* STUDENT EXCLUSIVE VIEW *@
            @if (role == "Student" || user.RoleId == 2)
            {
                <div class="text-uppercase text-muted small fw-bold mt-3 mb-2 ps-3 font-monospace" style="letter-spacing: 1px; font-size: 0.75rem;">
                    Student Services
                </div>
                <div class="nav-item mb-1">
                    <NavLink class="nav-link text-white d-flex align-items-center rounded-3 px-3 py-2" href="courses">
                        <i class="bi bi-book text-primary me-3 fs-5"></i> My Courses
                    </NavLink>
                </div>
                <div class="nav-item mb-1">
                    <NavLink class="nav-link text-white d-flex align-items-center rounded-3 px-3 py-2" href="transport">
                        <i class="bi bi-bus-front text-success me-3 fs-5"></i> Transport Booking
                    </NavLink>
                </div>
                <div class="nav-item mb-1">
                    <NavLink class="nav-link text-white d-flex align-items-center rounded-3 px-3 py-2" href="Library">
                        <i class="bi bi-bookmark-star text-warning me-3 fs-5"></i> Library Wing
                    </NavLink>
                </div>
                <div class="nav-item mb-1">
                    <NavLink class="nav-link text-white d-flex align-items-center rounded-3 px-3 py-2" href="fees">
                        <i class="bi bi-cash-stack text-danger me-3 fs-5"></i> My Fees
                    </NavLink>
                </div>
                <div class="nav-item mb-1">
                    <NavLink class="nav-link text-white d-flex align-items-center rounded-3 px-3 py-2" href="Complaints">
                        <i class="bi bi-exclamation-octagon text-info me-3 fs-5"></i> Complaints
                    </NavLink>
                </div>
                <div class="nav-item mb-1">
                    <NavLink class="nav-link text-white d-flex align-items-center rounded-3 px-3 py-2" href="events">
                        <i class="bi bi-calendar4-event text-light me-3 fs-5"></i> Campus Events
                    </NavLink>
                </div>
            }

            @* ADMIN EXCLUSIVE VIEW *@
            @if (role == "Admin" || user.RoleId == 1)
            {
                <div class="text-uppercase text-warning small fw-bold mt-4 mb-2 ps-3 font-monospace" style="letter-spacing: 1px; font-size: 0.75rem;">
                    Admin Tools
                </div>
                <div class="nav-item mb-1">
                    <NavLink class="nav-link text-white d-flex align-items-center rounded-3 px-3 py-2" href="RoleManagement">
                        <i class="bi bi-shield-lock text-warning me-3 fs-5"></i> Role Management
                    </NavLink>
                </div>
                <div class="nav-item mb-1">
                    <NavLink class="nav-link text-white d-flex align-items-center rounded-3 px-3 py-2" href="faculty">
                        <i class="bi bi-people text-info me-3 fs-5"></i> Faculty Management
                    </NavLink>
                </div>
            }

            @* COMMON PORTALS BLOCK (Shared UI Destinations) *@
            <div class="text-uppercase text-muted small fw-bold mt-4 mb-2 ps-3 font-monospace" style="letter-spacing: 1px; font-size: 0.75rem;">
                Academic & Utilities
            </div>
            <div class="nav-item mb-1">
                <NavLink class="nav-link text-white d-flex align-items-center rounded-3 px-3 py-2" href="exams">
                    <i class="bi bi-calendar-event text-danger me-3 fs-5"></i> Exam Schedule
                </NavLink>
            </div>
            <div class="nav-item mb-1">
                <NavLink class="nav-link text-white d-flex align-items-center rounded-3 px-3 py-2" href="hostel">
                    <i class="bi bi-house-door text-primary me-3 fs-5"></i> Hostel Rooms
                </NavLink>
            </div>
            <div class="nav-item mb-1">
                <NavLink class="nav-link text-white d-flex align-items-center rounded-3 px-3 py-2" href="cafe">
                    <i class="bi bi-cart text-success me-3 fs-5"></i> Café Menu
                </NavLink>
            </div>

            @* USER DETAIL PROFILE BANNER / LOGOUT *@
            <div class="mt-5 pt-3 border-top border-secondary">
                <div class="d-flex align-items-center mb-3 px-3 py-2 rounded bg-secondary bg-opacity-10 text-white">
                    <i class="bi bi-person-circle fs-3 text-muted me-3"></i>
                    <div class="text-truncate">
                        <div class="fw-bold text-truncate" style="font-size: 0.9rem;">@user.FullName</div>
                        <span class="text-muted small">ID: #@user.UserId</span>
                    </div>
                </div>
                <button class="btn btn-outline-danger w-100 border-0 d-flex align-items-center px-3 py-2 justify-content-start rounded-3" onclick="window.location.href='/login'">
                    <i class="bi bi-box-arrow-left me-3 fs-5"></i> Sign Out
                </button>
            </div>
        }
        else
        {
            <div class="nav-item mt-4">
                <NavLink class="nav-link text-white d-flex align-items-center rounded-3 px-3 py-2" href="login">
                    <i class="bi bi-box-arrow-in-right text-success me-3 fs-5"></i> Portal Login
                </NavLink>
            </div>
        }
    </nav>
</div>