@using CampusServicePortal.Data
@inject UserSession Session

<div class="nav-scrollable">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">Dashboard</NavLink>
        </div>

        @* If a user exists in session, show everything *@
        @if (Session.CurrentUser != null)
        {
            <div class="nav-item px-3"><NavLink class="nav-link" href="Complaints">Complaints</NavLink></div>
            <div class="nav-item px-3"><NavLink class="nav-link" href="transport">Transport</NavLink></div>
            <div class="nav-item px-3"><NavLink class="nav-link" href="events">Events</NavLink></div>
            <div class="nav-item px-3"><NavLink class="nav-link" href="Library">Library</NavLink></div>

            @* Only show Admin if the role matches *@
            @if (Session.CurrentUser.Role?.RoleName == "Admin")
            {
                <div class="nav-item px-3 border-top mt-2">
                    <NavLink class="nav-link text-warning" href="RoleManagement">Admin Panel</NavLink>
                </div>
            }

            <div class="nav-item px-3 mt-3">
                <button class="btn btn-link nav-link text-danger" @onclick="DoLogout">Logout</button>
            </div>
        }
        else
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="login">Login</NavLink>
            </div>
        }
    </nav>
</div>

@code {
    private void DoLogout()
    {
        Session.Logout();
    }
}