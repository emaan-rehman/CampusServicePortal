@using CampusServicePortal.Data

<div class="sidebar-wrapper" style="background-color: #0A192F; height: 100vh; width: 100%; display: flex; flex-direction: column; overflow: hidden; box-sizing: border-box;">
    
    <div style="display: flex; align-items: center; padding: 0 1.5rem; height: 70px; min-height: 70px; background-color: #020C1B; border-bottom: 1px solid rgba(255,255,255,0.06); flex-shrink: 0;">
        <div style="display: flex; align-items: center; justify-content: center; background-color: rgba(56, 189, 248, 0.1); width: 38px; height: 38px; min-width: 38px; border: 1px solid rgba(100, 255, 218, 0.25); border-radius: 8px; margin-right: 12px;">
            <i class="bi bi-mortarboard-fill" style="color: #38BDF8; font-size: 1.25rem;"></i>
        </div>
        <span style="color: #FFFFFF; font-weight: 700; font-size: 1.15rem; letter-spacing: 0.75px; font-family: 'Inter', sans-serif;">Smart Campus</span>
    </div>

    <div style="flex-grow: 1; overflow-y: auto; padding: 1.5rem 1rem;">
        <nav style="display: flex; flex-direction: column; width: 100%; padding: 0; margin: 0; list-style: none;">
            
            <NavLink class="nav-link custom-nav-tile" href="" Match="NavLinkMatch.All">
                <div class="tile-icon-frame"><i class="bi bi-columns-gap"></i></div>
                <span class="tile-text-lbl">Dashboard Panel</span>
            </NavLink>

            @if (UserSession.CurrentUser != null)
            {
                var user = UserSession.CurrentUser;
                var role = user.Role?.RoleName;

                @if (role == "Student" || user.RoleId == 2)
                {
                    <div style="display: flex; align-items: center; font-weight: 700; font-size: 0.725rem; letter-spacing: 1.5px; color: #64FFDA; text-transform: uppercase; padding: 1.25rem 0.5rem 0.65rem 0.5rem;">
                        <span style="width: 6px; height: 6px; border-radius: 50%; background-color: #64FFDA; margin-right: 8px; display: inline-block; box-shadow: 0 0 6px #64FFDA;"></span> Academic Core
                    </div>
                    
                    <NavLink class="nav-link custom-nav-tile" href="courses">
                        <div class="tile-icon-frame"><i class="bi bi-book"></i></div>
                        <span class="tile-text-lbl">My Courses</span>
                    </NavLink>
                    
                    <NavLink class="nav-link custom-nav-tile" href="transport">
                        <div class="tile-icon-frame"><i class="bi bi-bus-front"></i></div>
                        <span class="tile-text-lbl">Transport Route</span>
                    </NavLink>
                    
                    <NavLink class="nav-link custom-nav-tile" href="Library">
                        <div class="tile-icon-frame"><i class="bi bi-journal-bookmark"></i></div>
                        <span class="tile-text-lbl">Digital Library</span>
                    </NavLink>

                    @* --- NEW: EXAM SCHEDULE TILE --- *@
                    <NavLink class="nav-link custom-nav-tile" href="Exams">
                        <div class="tile-icon-frame"><i class="bi bi-calendar2-range"></i></div>
                        <span class="tile-text-lbl">Exam Schedule</span>
                    </NavLink>
                    
                    <NavLink class="nav-link custom-nav-tile" href="Fees">
                        <div class="tile-icon-frame"><i class="bi bi-credit-card"></i></div>
                        <span class="tile-text-lbl">Tuition Fees</span>
                    </NavLink>

                    @* --- NEW: CAMPUS LIFE SECTION --- *@
                    <div style="display: flex; align-items: center; font-weight: 700; font-size: 0.725rem; letter-spacing: 1.5px; color: #38BDF8; text-transform: uppercase; padding: 1.5rem 0.5rem 0.65rem 0.5rem;">
                        <span style="width: 6px; height: 6px; border-radius: 50%; background-color: #38BDF8; margin-right: 8px; display: inline-block; box-shadow: 0 0 6px #38BDF8;"></span> Campus Services
                    </div>

                    <NavLink class="nav-link custom-nav-tile" href="Hostel">
                        <div class="tile-icon-frame"><i class="bi bi-building"></i></div>
                        <span class="tile-text-lbl">Hostel Rooms</span>
                    </NavLink>

                    <NavLink class="nav-link custom-nav-tile" href="Cafe">
                        <div class="tile-icon-frame"><i class="bi bi-egg-fried"></i></div>
                        <span class="tile-text-lbl">Cafeteria Menu</span>
                    </NavLink>

                    <NavLink class="nav-link custom-nav-tile" href="Events">
                        <div class="tile-icon-frame"><i class="bi bi-calendar-event"></i></div>
                        <span class="tile-text-lbl">Campus Events</span>
                    </NavLink>
                    
                    <NavLink class="nav-link custom-nav-tile" href="Complaints">
                        <div class="tile-icon-frame"><i class="bi bi-chat-left-dots"></i></div>
                        <span class="tile-text-lbl">Helpdesk</span>
                    </NavLink>
                }

                @if (role == "Admin" || user.RoleId == 1)
                {
                    <div style="display: flex; align-items: center; font-weight: 700; font-size: 0.725rem; letter-spacing: 1.5px; color: #F59E0B; text-transform: uppercase; padding: 1.5rem 0.5rem 0.65rem 0.5rem;">
                        <span style="width: 6px; height: 6px; border-radius: 50%; background-color: #F59E0B; margin-right: 8px; display: inline-block; box-shadow: 0 0 6px #F59E0B;"></span> Administration Control
                    </div>
                    
                    <NavLink class="nav-link custom-nav-tile" href="RoleManagement">
                        <div class="tile-icon-frame"><i class="bi bi-shield-lock"></i></div>
                        <span class="tile-text-lbl">Access Control</span>
                    </NavLink>
                    
                    <NavLink class="nav-link custom-nav-tile" href="faculty">
                        <div class="tile-icon-frame"><i class="bi bi-person-badge"></i></div>
                        <span class="tile-text-lbl">Faculty Registry</span>
                    </NavLink>
                }
            }
        </nav>
    </div>

    @if (UserSession.CurrentUser != null)
    {
        <div style="padding: 1rem; padding-bottom: 1.5rem; flex-shrink: 0; width: 100%; box-sizing: border-box;">
            <div style="background: linear-gradient(135deg, rgba(255,255,255,0.04) 0%, rgba(255,255,255,0.01) 100%); padding: 12px 16px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.06); display: flex; align-items: center; width: 100%; box-sizing: border-box; box-shadow: inset 0 1px 1px rgba(255,255,255,0.1);">
                <div style="background-color: #38BDF8; color: #0A192F; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; margin-right: 12px; width: 40px; height: 40px; min-width: 40px; font-size: 0.95rem; border: 2px solid rgba(56, 189, 248, 0.25);">
                    @UserSession.CurrentUser.FullName.Substring(0, 1).ToUpper()
                </div>
                <div style="overflow: hidden; display: flex; flex-direction: column;">
                    <div style="color: #FFFFFF; font-weight: 600; font-size: 0.875rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@UserSession.CurrentUser.FullName</div>
                    <small style="color: #94A3B8; font-family: monospace; font-size: 0.725rem; margin-top: 2px;">ID: #@UserSession.CurrentUser.UserId</small>
                </div>
            </div>
        </div>
    }
</div>