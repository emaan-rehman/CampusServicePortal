@using CampusServicePortal.Data

<div class="navbar navbar-dark bg-primary-dark px-4 py-3 border-bottom border-blue-glow">
    <a class="navbar-brand fw-extrabold text-white d-flex align-items-center m-0" href="">
        <i class="bi bi-mortarboard-fill text-info me-2 fs-4"></i>
        <span class="tracking-wide text-uppercase" style="font-size: 1.1rem; letter-spacing: 1px;">Smart Campus</span>
    </a>
</div>

<div class="sidebar-body bg-navy-gradient">
    <nav class="flex-column nav-pills px-3 py-4 gap-1">
        
        @* CORE ROOT ENTRY *@
        <div class="nav-item mb-2">
            <NavLink class="nav-link custom-nav-link d-flex align-items-center rounded-3 px-3 py-2.5" href="" Match="NavLinkMatch.All">
                <i class="bi bi-grid-1x2-fill me-3 fs-5"></i>
                <span>Dashboard Center</span>
            </NavLink>
        </div>

        @if (UserSession.CurrentUser != null)
        {
            var user = UserSession.CurrentUser;
            var role = user.Role?.RoleName;

            @* STUDENT SECTION UTILITIES *@
            @if (role == "Student" || user.RoleId == 2)
            {
                <div class="sidebar-heading text-uppercase text-info-muted small fw-bold mt-4 mb-2 ps-3 font-monospace">
                    Academic Hub
                </div>
                <div class="nav-item">
                    <NavLink class="nav-link custom-nav-link d-flex align-items-center rounded-3 px-3 py-2" href="courses">
                        <i class="bi bi-journal-bookmark-fill me-3 fs-5"></i> Courses
                    </NavLink>
                </div>
                <div class="nav-item">
                    <NavLink class="nav-link custom-nav-link d-flex align-items-center rounded-3 px-3 py-2" href="transport">
                        <i class="bi bi-bus-front-fill me-3 fs-5"></i> Transport Track
                    </NavLink>
                </div>
                <div class="nav-item">
                    <NavLink class="nav-link custom-nav-link d-flex align-items-center rounded-3 px-3 py-2" href="Library">
                        <i class="bi bi-book-half me-3 fs-5"></i> Digital Library
                    </NavLink>
                </div>
                <div class="nav-item">
                    <NavLink class="nav-link custom-nav-link d-flex align-items-center rounded-3 px-3 py-2" href="fees">
                        <i class="bi bi-wallet2 me-3 fs-5"></i> Tuition & Fees
                    </NavLink>
                </div>
                <div class="nav-item">
                    <NavLink class="nav-link custom-nav-link d-flex align-items-center rounded-3 px-3 py-2" href="events">
                        <i class="bi bi-calendar3 me-3 fs-5"></i> Campus Events
                    </NavLink>
                </div>
                <div class="nav-item">
                    <NavLink class="nav-link custom-nav-link d-flex align-items-center rounded-3 px-3 py-2" href="Complaints">
                        <i class="bi bi-chat-square-text-fill me-3 fs-5"></i> Helpdesk Tickets
                    </NavLink>
                </div>
            }

            @* ADMINISTRATIVE PRIVILEGE CONTROLS *@
            @if (role == "Admin" || user.RoleId == 1)
            {
                <div class="sidebar-heading text-uppercase text-warning small fw-bold mt-4 mb-2 ps-3 font-monospace" style="letter-spacing: 0.5px;">
                    Control Terminal
                </div>
                <div class="nav-item">
                    <NavLink class="nav-link custom-nav-link d-flex align-items-center rounded-3 px-3 py-2" href="RoleManagement">
                        <i class="bi bi-fingerprint me-3 fs-5 text-warning"></i> Access Keys
                    </NavLink>
                </div>
                <div class="nav-item">
                    <NavLink class="nav-link custom-nav-link d-flex align-items-center rounded-3 px-3 py-2" href="faculty">
                        <i class="bi bi-person-workspace me-3 fs-5"></i> Faculty Registry
                    </NavLink>
                </div>
            }

            @* GLOBAL RESOURCE CHANNELS *@
            <div class="sidebar-heading text-uppercase text-info-muted small fw-bold mt-4 mb-2 ps-3 font-monospace">
                Campus Base
            </div>
            <div class="nav-item">
                <NavLink class="nav-link custom-nav-link d-flex align-items-center rounded-3 px-3 py-2" href="exams">
                    <i class="bi bi-calendar-check me-3 fs-5"></i> Examination Desk
                </NavLink>
            </div>
            <div class="nav-item">
                <NavLink class="nav-link custom-nav-link d-flex align-items-center rounded-3 px-3 py-2" href="hostel">
                    <i class="bi bi-building-fill me-3 fs-5"></i> Hostel Portals
                </NavLink>
            </div>
            <div class="nav-item">
                <NavLink class="nav-link custom-nav-link d-flex align-items-center rounded-3 px-3 py-2" href="cafe">
                    <i class="bi bi-cup-straw me-3 fs-5"></i> Café Lounge
                </NavLink>
            </div>

            @* LOGOUT & USER STATE ATTACHMENT *@
            <div class="mt-auto pt-4 border-top border-blue-glow">
                <div class="user-meta-capsule d-flex align-items-center p-2.5 rounded-3 mb-2 mx-2">
                    <div class="meta-avatar bg-info text-dark fw-bold me-2 rounded-circle">
                        @user.FullName.Substring(0, 1).ToUpper()
                    </div>
                    <div class="text-truncate">
                        <div class="text-white fw-semibold small text-truncate">@user.FullName</div>
                        <span class="text-info-muted font-monospace" style="font-size: 0.75rem;">Active Token</span>
                    </div>
                </div>
                <button class="btn btn-logout w-100 border-0 text-start px-3 py-2 rounded-3 text-danger d-flex align-items-center" onclick="window.location.href='/login'">
                    <i class="bi bi-power me-3 fs-5"></i> Secure Sign Out
                </button>
            </div>
        }
        else
        {
            <div class="nav-item mt-4">
                <NavLink class="nav-link custom-nav-link text-white d-flex align-items-center rounded-3 px-3 py-2" href="login">
                    <i class="bi bi-shield-lock-fill text-info me-3 fs-5"></i> Gateway Login
                </NavLink>
            </div>
        }
    </nav>
</div>