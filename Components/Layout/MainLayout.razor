@inherits LayoutComponentBase
@using CampusServicePortal.Data
@inject UserSession Session

<div class="container-fluid p-0 d-flex" style="min-height: 100vh; background-color: #f4f7fe; overflow-x: hidden;">
    
    <div class="d-flex flex-column flex-shrink-0 text-white" style="width: 280px; background-color: #0A192F; min-height: 100vh; box-shadow: 4px 0 15px rgba(0,0,0,0.05);">
        <NavMenu />
    </div>

    <div class="d-flex flex-column flex-grow-1" style="min-width: 0;">
        
        <header class="navbar navbar-expand navbar-light bg-white px-4 border-bottom justify-content-end align-items-center" style="height: 70px;">
            @if (Session.IsLoggedIn)
            {
                <div class="d-flex align-items-center gap-3">
                    <div class="px-3 py-1.5 rounded-pill border d-flex align-items-center gap-2" style="background-color: #f0fdf4; border-color: #bbf7d0 !important; color: #166534; font-size: 0.85rem; font-weight: 600;">
                        <span class="p-1 bg-success rounded-circle" style="width: 6px; height: 6px;"></span>
                        <span>Active Session: <strong>@UserSession.CurrentUser?.FullName</strong></span>
                    </div>
                    <a href="login" class="btn btn-sm btn-outline-danger px-3 fw-bold" style="border-radius: 8px;" @onclick="() => Session.Logout()">
                        Sign Out
                    </a>
                </div>
            }
            else
            {
                <a href="login" class="btn btn-sm btn-primary px-4 fw-bold shadow-sm" style="background-color: #0284c7; border-color: #0284c7; border-radius: 8px;">
                    System Portal Login
                </a>
            }
        </header>

        <main class="w-100 flex-grow-1">
            @Body
        </main>
    </div>
</div>