@inherits LayoutComponentBase
@using CampusServicePortal.Data
@inject UserSession Session

<div class="portal-master-layout" style="display: flex; flex-direction: row; width: 100vw; height: 100vh; overflow: hidden; background-color: #F4F7FE; margin: 0; padding: 0; box-sizing: border-box;">
    
    <aside style="width: 280px; min-width: 280px; max-width: 280px; height: 100vh; background-color: #0A192F; display: flex; flex-direction: column; flex-shrink: 0; border-right: 1px solid rgba(255, 255, 255, 0.06); z-index: 1000; box-sizing: border-box; margin: 0; padding: 0;">
        <NavMenu />
    </aside>

    <div style="flex-grow: 1; height: 100vh; display: flex; flex-direction: column; overflow: hidden; box-sizing: border-box; margin: 0; padding: 0;">
        
        <header class="d-flex align-items-center justify-content-end px-4 border-bottom bg-white shadow-sm" style="height: 70px; min-height: 70px; border-color: #E2E8F0 !important; flex-shrink: 0; box-sizing: border-box; width: 100%;">
            @if (UserSession.CurrentUser != null)
            {
                <div class="d-flex align-items-center gap-3">
                    <span class="badge bg-success bg-opacity-10 text-success px-3 py-2 rounded-pill d-flex align-items-center gap-2 fw-semibold border border-success border-opacity-10" style="font-size: 0.825rem;">
                        <span class="spinner-grow spinner-grow-sm text-success" style="width: 6px; height: 6px; animation-duration: 2s;"></span>
                        <i class="bi bi-shield-check-fill"></i> Connected Securely
                    </span>
                    
                    <a href="logout" class="btn d-flex align-items-center gap-2 px-3 py-2 rounded-3 fw-medium shadow-sm" style="font-size: 0.85rem; border: 1px solid #FEE2E2; background-color: #FFF5F5; color: #EF4444; text-decoration: none;">
                        <i class="bi bi-box-arrow-right"></i> Sign Out
                    </a>
                </div>
            }
            else
            {
                <a href="login" class="btn d-flex align-items-center gap-2 px-4 py-2 rounded-3 fw-medium shadow-sm border-0" style="font-size: 0.85rem; background: linear-gradient(135deg, #2563EB 0%, #1D4ED8 100%); color: #FFF; text-decoration: none;">
                    <i class="bi bi-box-arrow-in-right"></i> System Portal Login
                </a>
            }
        </header>

        <main style="flex-grow: 1; padding: 2.25rem; overflow-y: auto; width: 100%; box-sizing: border-box; background-color: #F4F7FE;">
            @Body
        </main>
    </div>
</div>