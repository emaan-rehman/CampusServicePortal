@inherits LayoutComponentBase
@using CampusServicePortal.Data
@inject UserSession Session

<div class="portal-frame">
    <div class="portal-sidebar-area">
        <NavMenu />
    </div>

    <div class="portal-content-area">
        <header class="portal-top-bar">
            @if (Session.IsLoggedIn)
            {
                <div class="d-flex align-items-center gap-3">
                    <div class="user-pill">
                        <i class="bi bi-shield-check-fill text-success fs-5"></i>
                        <span>Active Connection: <strong>@UserSession.CurrentUser?.FullName</strong></span>
                    </div>
                    <a href="login" class="action-logout-btn" @onclick="() => Session.Logout()">
                        <i class="bi bi-box-arrow-right me-1"></i> Sign Out
                    </a>
                </div>
            }
            else
            {
                <a href="login" class="action-login-btn">
                    <i class="bi bi-box-arrow-in-right me-1"></i> Account Gateway Login
                </a>
            }
        </header>

        <main class="flex-grow-1">
            @Body
        </main>
    </div>
</div>