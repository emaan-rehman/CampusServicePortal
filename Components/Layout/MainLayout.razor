@inherits LayoutComponentBase
@using CampusServicePortal.Data
@inject UserSession Session

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            @if (Session.IsLoggedIn)
            {
                <span class="me-3">Welcome, <strong>@UserSession.CurrentUser?.FullName</strong></span>
                <a href="login" @onclick="() => Session.Logout()">Logout</a>
            }
            else
            {
                <a href="login">Login</a>
            }
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>