@inherits LayoutComponentBase
@using CampusServicePortal.Data
@inject UserSession Session

<div class="portal-frame">
    <aside class="portal-sidebar-area">
        <NavMenu />
    </aside>

    <div class="portal-content-area">
        <header class="portal-top-bar shadow-sm">
            @if (UserSession.CurrentUser != null)
            {
                <div class="d-flex align-items-center gap-3">
                    <span class="user-pill">
                        <span class="bg-success rounded-circle" style="width: 8px; height: 8px; display: inline-block;"></span>
                        <i class="bi bi-shield-check text-success"></i> Connected Securely
                    </span>
                    <a href="logout" class="action-logout-btn">
                        <i class="bi bi-box-arrow-right me-1"></i> Sign Out
                    </a>
                </div>
            }
            else
            {
                <a href="login" class="action-login-btn">
                    <i class="bi bi-box-arrow-in-right me-1"></i> System Portal Login
                </a>
            }
        </header>

        <main class="workspace-outer overflow-auto flex-grow-1">
            @Body
        </main>
    </div>
</div>